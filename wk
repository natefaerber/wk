# helpers
# ---------------------------------------------------------------------------


def run(
    cmd: list[str],
    *,
    check: bool = True,
    capture: bool = True,
    cwd: Optional[Path] = None,
) -> subprocess.CompletedProcess[str]:
    """Run a command, returning the completed process."""
    return subprocess.run(
        cmd,
        check=check,
        capture_output=capture,
        text=True,
        cwd=cwd,
    )


def die(msg: str, code: int = 1, *, hint: Optional[str] = None) -> NoReturn:
    """Print `error: <msg>` and exit. An optional HINT prints on the next
    line as a dimmed `→ …` next step, so failures point at the fix instead
    of leaving the user to guess the recovery command."""
    err.print(f"[red]error:[/red] {msg}")
    if hint:
        err.print(f"[dim]→ {hint}[/dim]")
    raise typer.Exit(code)


def warn(msg: str) -> None:
    """Print `warning: <msg>` to stderr — a non-fatal advisory. Pairs with
    `die()` (fatal `error:`) so the CLI speaks one prefix vocabulary: red
    `error:` for things that stop, yellow `warning:` for things that don't."""
    err.print(f"[yellow]warning:[/yellow] {msg}")


def require(tool: str) -> None:
    if shutil.which(tool) is None:
        die(f"{tool!r} not found on PATH")


def _log_detached_failure(logdir: Path, label: str) -> None:
    """Append the current exception traceback to `<logdir>/wk-detached.log`.

    The detached children (`_rm-detached`, `_relayout-detached`) run with
    stdout/stderr pointed at /dev/null so the dying session's SIGHUP can't
    reach them — which also means a crash there is otherwise invisible,
    leaving e.g. a half-removed worktree with no signal anywhere. Logging to
    a stable file (the main repo's `.git`, which outlives the worktree being
    removed) makes those failures diagnosable after the fact.
    """
    import traceback

    try:
        logdir.mkdir(parents=True, exist_ok=True)
        stamp = _time.strftime("%Y-%m-%d %H:%M:%S")
        with (logdir / "wk-detached.log").open("a", encoding="utf-8") as f:
            f.write(f"\n--- {label} failed at {stamp} ---\n")
            f.write(traceback.format_exc())
    except Exception:
        pass  # logging must never mask the original failure


def repo_root() -> Path:
    """Toplevel of the *main* repo (not the worktree we may be in)."""
    try:
        r = run(["git", "rev-parse", "--path-format=absolute", "--git-common-dir"])
    except subprocess.CalledProcessError:
        die("not inside a git repository",
            hint="cd into a git repo, or run `git init` here first")
    common_dir = Path(r.stdout.strip())
    # common_dir is .../<repo>/.git — parent is the main checkout
    return common_dir.parent


def repo_name() -> str:
    return repo_root().name


def worktree_root() -> Path:
    """Where all worktrees for this repo live.

    Default is `<repo>/.worktrees/` — nested inside the main checkout so each
    repo's worktrees stay co-located with it. `ensure_worktrees_ignored()`
    keeps that dir out of the parent repo's `git status`. Override the whole
    location (e.g. back to a sibling dir) with WK_WORKTREE_ROOT.
    """
    override = os.environ.get(WORKTREE_ROOT_ENV)
    if override:
        return Path(override).expanduser()
    return repo_root() / ".worktrees"


def worktree_path(branch: str) -> Path:
    # branches like `feat/foo` become `feat-foo` on disk to avoid nested dirs
    safe = branch.replace("/", "-")
    return worktree_root() / safe


def ensure_worktrees_ignored() -> None:
    """Keep the in-repo `.worktrees/` dir out of the main repo's `git status`.

    With the default layout, worktrees nest inside the main checkout, so git
    would otherwise report `.worktrees/` as untracked. We add it to
    `.git/info/exclude` rather than the tracked `.gitignore` so we don't dirty
    the user's repo or force a commit. No-op when WK_WORKTREE_ROOT points the
    worktrees somewhere outside the repo.

    Idempotent: only the first call writes the line.
    """
    # Only relevant when worktrees actually live inside the repo.
    main = repo_root()
    try:
        rel = worktree_root().resolve().relative_to(main.resolve())
    except ValueError:
        return  # worktree root is outside the repo — nothing to exclude

    # `--git-common-dir` resolves to the *main* repo's .git even from a worktree.
    common = run(
        ["git", "-C", str(main), "rev-parse", "--path-format=absolute", "--git-common-dir"]
    ).stdout.strip()
    exclude = Path(common) / "info" / "exclude"
    entry = f"/{rel.as_posix()}/"

    existing = exclude.read_text(encoding="utf-8") if exclude.exists() else ""
    if entry in existing.split():
        return
    exclude.parent.mkdir(parents=True, exist_ok=True)
    prefix = "" if existing == "" or existing.endswith("\n") else "\n"
    with exclude.open("a", encoding="utf-8") as f:
        f.write(f"{prefix}{entry}\n")


def _normalize_session(s: str) -> str:
    # tmux session names can't contain `.` or `:`, and `/` would read as a
    # window path. Normalize all three to `-`. This is the bare branch slug,
    # also used to match session-form aliases (`feat/login` ↔ `feat-login`).
    return s.replace("/", "-").replace(".", "-").replace(":", "-")


@functools.lru_cache(maxsize=None)
def _project_prefix(cwd: str) -> str:
    """Slugified name of the *main* repo for the project at CWD, or "".

    This is the project component of a session name (see `session_name`).
    Keyed on CWD and cached because session_name is called in tight loops
    over worktrees, and because cross-repo flows `os.chdir` into a
    different repo mid-run — the key change picks up the new project.
    Best-effort: outside a git repo we return "" and fall back to a bare
    branch name, rather than dying just to compute a label.
    """
    try:
        r = run(
            ["git", "rev-parse", "--path-format=absolute", "--git-common-dir"],
            check=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""
    # common_dir is .../<repo>/.git — its parent is the main checkout.
    return _normalize_session(Path(r.stdout.strip()).parent.name)


def session_name(branch: str) -> str:
    """tmux session name for BRANCH, scoped to the current project.

    Prefixed with the repo name so two checkouts of *different* projects
    that happen to sit on the same branch — classically both on `main`,
    e.g. via `wk adopt` — don't resolve to one shared tmux session. Within
    a single repo the prefix is constant, so every lookup stays consistent;
    across repos the prefix differs, which is what breaks the collision.
    """
    base = _normalize_session(branch)
    prefix = _project_prefix(os.getcwd())
    return f"{prefix}-{base}" if prefix else base


def agent_cmd() -> str:
    return os.environ.get(AGENT_CMD_ENV, DEFAULT_AGENT_CMD)


@dataclass
class Workspace:
    branch: str
    path: Path
    session: str
    has_session: bool
    dirty: bool
    ahead: int
    behind: int


# ── workspace-state rendering ──────────────────────────────────────
# Every surface that lists workspaces — `wk list`, the `switch` fzf
# picker, the passive sidebar, the dashboard, and the fzf `_list-once`
# reload — speaks ONE visual vocabulary for session state and worktree
# cleanliness. Defined once here so the surfaces a user flips between
# never drift into different symbol languages. (They used to: `list`
# showed ●/○ while everything else showed ▶/●/·, and the dashboard
# dropped the current-session marker entirely.)
#   ▶  current session — the one you're attached to
#   ●  a running wk session (not the current one)
#   ·  no session — worktree exists, nothing attached
#   ✱  dirty worktree (uncommitted changes)
GLYPH_CURRENT = "▶"
GLYPH_RUNNING = "●"
GLYPH_IDLE = "·"
GLYPH_DIRTY = "✱"
GLYPH_DONE = "✓"


def task_done(w: "Workspace") -> bool:
    """True if W is a finished `--auto` task — the `.wk/done` sentinel exists.
    Only `--auto` task workspaces ever write it, so the file's presence alone
    identifies a done task (no tmux call needed)."""
    return (w.path / WK_MARKER_DIR / _TASK_DONE_MARKER).exists()


def current_session() -> str:
    """The tmux session we're rendering "from", used to mark it with ▶.

    Prefers $WK_CURRENT (exported into picker popups so a reload sees the
    same value); falls back to asking tmux directly when we're attached
    but it wasn't exported. Empty string when not in tmux at all.
    """
    current = os.environ.get("WK_CURRENT", "")
    if not current and in_tmux():
        r = run(["tmux", "display-message", "-p", "#S"], check=False)
        current = r.stdout.strip()
    return current


def session_marker(w: "Workspace", current: str = "", *, rich: bool = True) -> str:
    """Session-state glyph for W (▶ current / ● running / · idle).

    rich=True wraps it in Rich color tags (for console surfaces);
    rich=False returns the bare glyph (for fzf/ANSI surfaces).

    A finished `--auto` task shows ✓ regardless of session state — "this task
    is done, ready to merge" is the signal that matters most for it.
    """
    if task_done(w):
        return f"[green]{GLYPH_DONE}[/green]" if rich else GLYPH_DONE
    if w.session == current:
        return f"[green]{GLYPH_CURRENT}[/green]" if rich else GLYPH_CURRENT
    if w.has_session:
        return f"[cyan]{GLYPH_RUNNING}[/cyan]" if rich else GLYPH_RUNNING
    return f"[dim]{GLYPH_IDLE}[/dim]" if rich else GLYPH_IDLE


def dirty_marker(w: "Workspace", *, rich: bool = True) -> str:
    """Dirty-worktree glyph (✱) for W, or a single space when clean so
    columns stay aligned across rows."""
    if not w.dirty:
        return " "
    return f"[red]{GLYPH_DIRTY}[/red]" if rich else GLYPH_DIRTY


def ahead_behind(w: "Workspace") -> str:
    """`+A/-B` ahead/behind summary, or "" when the branch is in sync."""
    return f"+{w.ahead}/-{w.behind}" if (w.ahead or w.behind) else ""


def _picker_line(w: "Workspace", current: str) -> str:
    """One `session\\tdisplay` row for the fzf workspace picker.

    Shared by the `switch` picker and its `_list-once` reload: the two
    MUST emit identical rows, or the list visually jumps when fzf
    reloads after a destructive action.
    """
    marker = session_marker(w, current, rich=False)
    ab = ahead_behind(w) or " "
    status = dirty_marker(w, rich=False)
    # Repo column so the global hub's cross-repo rows are legible (two `main`s
    # in different repos are otherwise indistinguishable by branch alone).
    repo = _repo_label(w.path)
    display = f"{marker} {w.branch[:24]:<24} {repo[:14]:<14} {ab:>8} {status}"
    return f"{w.session}\t{display}"


def workspace_table(workspaces: list["Workspace"], current: str = "") -> Table:
    """The workspace table shared by `wk list` and the dashboard, so the
    one-shot listing and the auto-refreshing monitor never drift into
    different columns or glyphs."""
    table = Table(box=None, pad_edge=False, show_header=True, header_style="bold")
    table.add_column("", justify="center")          # session-state glyph
    table.add_column("branch", style="bold")
    table.add_column("session", style="dim")
    table.add_column("ahead/behind", justify="right")
    table.add_column("dirty", justify="center")
    table.add_column("path", style="dim")
    for w in workspaces:
        try:
            shown = "~/" + str(w.path.relative_to(Path.home()))
        except ValueError:
            shown = str(w.path)
        table.add_row(
            session_marker(w, current),
            w.branch,
            w.session,
            ahead_behind(w) or "[dim]·[/dim]",
            dirty_marker(w),
            shown,
        )
    return table


def _query_matches(query: str, branch_ref: str, session: Optional[str] = None) -> bool:
    """True if QUERY identifies BRANCH_REF.

    Accepts three forms so users can type whatever's handy: the exact
    branch (`feat/login`), the session-form slug (`feat-login`), or the
    full project-scoped session name (`wk-feat-login`). The slug form is
    what kept working before session names were project-prefixed, so we
    preserve it here.
    """
    if session is None:
        session = session_name(branch_ref)
    return query in (branch_ref, _normalize_session(branch_ref), session)


def _matches_query(query: str, w: "Workspace") -> bool:
    """`_query_matches` for a resolved Workspace (reuses its session name)."""
    return _query_matches(query, w.branch, w.session)


def list_worktrees() -> list[tuple[str, Path]]:
    """Parse `git worktree list --porcelain`. Returns (branch, path) pairs.

    Skips the main checkout and detached HEADs. Includes every worktree
    git knows about — use `list_wk_worktrees()` to filter to wk-owned ones.
    """
    # check=False: this backs all_workspaces() → wk list/switch/rm/dashboard and
    # the always-on sidebar/dashboard render loops. If git exits nonzero (CWD
    # outside a repo, a corrupt .git), a raised CalledProcessError would crash
    # every one of those, and permanently kill the render loops. Degrade to [].
    r = run(["git", "worktree", "list", "--porcelain"], check=False)
    if r.returncode != 0:
        return []
    out = r.stdout
    main = repo_root()
    results: list[tuple[str, Path]] = []
    cur_path: Optional[Path] = None
    cur_branch: Optional[str] = None
    for line in out.splitlines() + [""]:  # trailing blank flushes last record
        if line.startswith("worktree "):
            cur_path = Path(line[len("worktree ") :])
            cur_branch = None
        elif line.startswith("branch "):
            ref = line[len("branch ") :]
            cur_branch = ref.removeprefix("refs/heads/")
        elif line == "":
            if cur_path and cur_branch and cur_path != main:
                results.append((cur_branch, cur_path))
            cur_path = None
            cur_branch = None
    return results


def is_wk_workspace(
    branch: str,
    path: Path,
    wk_sessions: Optional[set[str]] = None,
) -> bool:
    """Worktree is a wk workspace if it has a .wk/ marker OR a wk-tagged
    tmux session is currently running for it.

    "wk-tagged" means the session has the `@wk` user option set, which
    `build_session` does. A plain tmux session that happens to share the
    branch name does NOT make the worktree a wk workspace.

    The session check covers worktrees created with `wk open` before the
    marker existed — they show up in the sidebar as long as the session is
    alive, and get marked permanently next time `build_session` runs.
    """
    if (path / WK_MARKER_DIR).is_dir():
        return True
    if wk_sessions is None:
        return False
    return session_name(branch) in wk_sessions


def list_wk_worktrees() -> list[tuple[str, Path]]:
    """Like `list_worktrees`, but only worktrees wk owns (marker or wk session)."""
    wk_sessions = wk_tmux_sessions()
    return [
        (b, p) for b, p in list_worktrees()
        if is_wk_workspace(b, p, wk_sessions)
    ]


# Branches treated as orchestrator workspaces (gets the orchestrator AGENTS).
# Extend via WK_ORCHESTRATOR_BRANCHES env var (comma-separated).
ORCHESTRATOR_BRANCHES = {"main", "master", "develop", "trunk"}


def is_orchestrator_branch(branch: str) -> bool:
    extra = os.environ.get("WK_ORCHESTRATOR_BRANCHES", "")
    branches = ORCHESTRATOR_BRANCHES | {
        b.strip() for b in extra.split(",") if b.strip()
    }
    return branch in branches


def _write_agents_md(path: Path, force: bool = False) -> bool:
    """Write .wk/AGENTS.md. Returns True if a write happened.

    With force=False, only writes if the file is missing — so users who've
    edited it locally aren't clobbered. With force=True, unconditional.
    """
    target = path / WK_MARKER_DIR / "AGENTS.md"
    if target.exists() and not force:
        return False
    target.parent.mkdir(exist_ok=True)
    target.write_text(_AGENTS_MD, encoding="utf-8")
    return True


def _write_orchestrator_md(path: Path, branch: str, force: bool = False) -> bool:
    """Write .wk/ORCHESTRATOR.md if BRANCH is an orchestrator branch.
    Returns True if a write happened, False if skipped or not applicable."""
    if not is_orchestrator_branch(branch):
        return False
    target = path / WK_MARKER_DIR / "ORCHESTRATOR.md"
    if target.exists() and not force:
        return False
    target.parent.mkdir(exist_ok=True)
    target.write_text(_ORCHESTRATOR_MD, encoding="utf-8")
    return True


def mark_wk_workspace(path: Path, branch: Optional[str] = None) -> None:
    """Create the .wk/ marker (idempotent). Also writes a .gitignore inside
    so the marker dir doesn't end up tracked in the worktree's git history,
    an AGENTS.md so coding agents (Claude, etc.) can self-orient, and an
    ORCHESTRATOR.md when BRANCH is one of the orchestrator branches.

    Existing agent docs are preserved — `wk refresh-agents` overwrites."""
    marker = path / WK_MARKER_DIR
    marker.mkdir(exist_ok=True)
    gi = marker / ".gitignore"
    if not gi.exists():
        gi.write_text("*\n!.gitignore\n", encoding="utf-8")
    _write_agents_md(path)
    if branch:
        _write_orchestrator_md(path, branch)


_AGENTS_MD = """\
# wk workspace context

This worktree is managed by `wk` (a tmux + git-worktree workspace manager).
When you read this file you can assume you're running inside the agent pane
of a wk tmux session.

## Runtime signals

These environment variables are set on every pane of the session:

- `WK_IN_WORKSPACE=1` — fast check that wk is active
- `WK_SESSION` — the tmux session name (slug form, no slashes)
- `WK_BRANCH` — the canonical git branch (may contain slashes)
- `WK_PATH` — the worktree root (typically equal to your starting cwd)

## Layout

The wk session is three columns (the `wide` layout):

  ┌──────────┬──────────────────────┬──────────────┐
  │ sidebar  │                      │              │
  ├──────────┤   agent (you)        │   terminal   │
  │ shell    │                      │              │
  └──────────┴──────────────────────┴──────────────┘

The left column stacks the sidebar over a shell; you're the centre; a
terminal is the right column. On a narrow display the `laptop` layout is
used instead: 2 columns, sidebar over a terminal on the left, you on the right.

There is no always-on lazygit pane. The user summons lazygit full-screen
with `prefix M-g`; it opens at the active pane's cwd, so it already follows
wherever you're working — you don't manage it.

## Useful wk commands

Lifecycle (when the user asks you to do something with a workspace):

- `wk open <branch|pr|issue>` — the one "get into the work" command. It
  accepts:
  - a branch name — switch to (or create) a wk workspace for it. Forgiving:
    works for local branches, remote-only branches, or fresh branches off
    `main`.
  - a pull request — a bare number (current repo) or a github PR URL (looked
    up in whichever clone under `~/_Work` matches that repo). Fork PRs are
    fetched via `refs/pull/<n>/head` into a `pr-<n>` branch.
  - an issue — a Jira link or bare key (e.g. `DEV-6266`), resolved to its PR
    (searching the current repo, then the repo's GitHub org); if no PR
    exists yet, a new workspace is started on a branch named after the key.
- `wk pr <number|url>` — the same PR path as an explicit, PR-only verb.
- `wk close [branch]` — kill the workspace's tmux session but keep the
  worktree on disk. Default: current session.
- `wk rm [branch]` — full destruction: kill session, remove worktree,
  delete branch. Default: current session (user binding is `prefix D`).

Parallel work (only from an orchestrator workspace — see ORCHESTRATOR.md):

- `wk task <prompt>` — spawn another wk workspace on a new branch.
- `wk task-status [branch]` — running / done / failed for task workspaces.
- `wk task-output <branch> [--tail N] [--follow]` — read a task's
  `.wk/output.md` (the `--auto` Claude's stdout).
- `wk task-merge <branch> [--squash] [--rm] [--into <orch>]` — merge a
  finished task branch back into the orchestrator's branch. `--rm` tears
  the task workspace down after a clean merge; `--into` targets an
  orchestrator other than the current session. A finished `--auto` task
  shows ✓ in the sidebar and messages the orchestrator when it's done.
- `wk task-cancel <branch>` — stop a running task's agent (kill its
  session), keeping the worktree and partial output.
- `wk task-retry <branch>` — re-run a task's agent against its existing
  `.wk/task.md`, in place (clears the prior output/done markers).

Inspection / housekeeping:

- `wk list` — show all wk workspaces with branch/status.
- `wk cd [branch]` — print the worktree path for `cd` integration.
- `wk refresh-agents` — regenerate this AGENTS.md (and ORCHESTRATOR.md
  if applicable) for the current workspace. Use when wk itself ships
  updated agent docs and you want to pick them up without rebuilding
  the session.

## Conventions

- The `.wk/` directory in this worktree is wk-managed and gitignored. You
  can write notes here (e.g. `.wk/notes.md`) that won't pollute the repo.
- The `.wk/task.md` file, if present, is the original task prompt that
  `wk task` was invoked with — useful as ground-truth context.
- If `.wk/ORCHESTRATOR.md` exists, you are an orchestrator workspace
  (not a worker). Read it for additional instructions about spawning
  and harvesting parallel tasks.
"""


_ORCHESTRATOR_MD = """\
# orchestrator workspace

You are running in an **orchestrator** wk workspace — a workspace on a
long-lived branch (`main`, `master`, `develop`, `trunk`) from which the
user spawns and supervises parallel task workspaces. Different rules
apply here than to a worker workspace.

## Your job

When the user describes work that can be parallelized (multiple
independent bugs, several scoped features, exploration in different
directions), you should:

1. **Scope** — decompose the request into independent units, each
   small enough to be a single PR. Talk through the decomposition
   before spawning anything.
2. **Spawn** — for each unit, run:
   ```
   wk task "<self-contained prompt>" --base <this branch> --auto
   ```
   Each `--auto` task spawns a sibling wk workspace + tmux session,
   runs `claude -p` headlessly with the prompt, and streams output
   to that workspace's `.wk/output.md`.
3. **Poll** — periodically check status:
   ```
   wk task-status                 # one-line summary of all tasks
   wk task-output <branch> --tail 50
   ```
   Don't poll in a tight loop. Wait for the user to ask for a check,
   or naturally check at decision points.
4. **Review** — when a task is `done`, read its full output, inspect
   the diff (`git diff <base>..<task-branch>`), and decide whether
   it's mergeable, needs revision, or should be abandoned.
5. **Integrate** — for mergeable tasks:
   ```
   wk task-merge <task-branch>          # --no-ff merge commit
   wk task-merge <task-branch> --squash # squash into one commit
   wk task-merge <task-branch> --rm     # merge, then tear the task down
   ```
   The merge happens in *this* worktree, against the current branch.
   `--rm` folds the clean-up step (6) into the merge: it removes the
   task's worktree and, when the branch is ancestor-merged, deletes it.
6. **Clean up** — after a task is merged, the child workspace is no
   longer needed. Either `wk close <task-branch>` (kill the session but
   keep the worktree on disk, in case you want to revisit) or
   `wk rm <task-branch>` (full destruction). Don't leave dozens of
   merged-and-done sessions sitting around — they clutter `wk
   task-status` and the popup picker.

## Rules

- **Don't recurse.** Never run `wk task` from inside a child workspace.
  If a worker needs sub-tasks, surface that back to the user — let them
  decide whether to split further from the orchestrator.
- **Don't run blocking commands** while supervising. The orchestrator
  is meant to be reactive: check status when asked, harvest when ready.
- **Tasks are immutable until merged.** Don't edit a child workspace's
  code from the orchestrator. If you want to revise, spawn a fresh task
  or instruct the user to enter that workspace.
- **Prompts must be self-contained.** Worker workspaces don't share your
  conversation history. Write each `wk task` prompt as if briefing a
  fresh engineer: include file paths, what to change, what to avoid.

## Useful state checks

- `wk list` — what workspaces exist right now
- `wk task-status` — running/done/failed per task workspace
- `git -C <task-worktree> log --oneline <base>..HEAD` — what changed
- `git -C <task-worktree> diff --stat <base>..HEAD` — at a glance
- `cat <task-worktree>/.wk/output.md` — the worker Claude's stdout

## When NOT to use parallel tasks

- Cross-cutting refactors that touch many files (merges will conflict)
- Anything that needs the user in the loop mid-task
- Quick edits you can do faster yourself in this workspace
- Exploratory questions where you don't know the answer yet
"""


def tmux_sessions() -> set[str]:
    r = run(["tmux", "ls", "-F", "#{session_name}"], check=False)
    if r.returncode != 0:
        return set()
    return {line.strip() for line in r.stdout.splitlines() if line.strip()}


def wk_tmux_sessions() -> set[str]:
    """Only sessions that wk created (have the `@wk` user option set).

    Distinguishes a wk-managed session from a plain tmux session that
    happens to share a name with a git branch.
    """
    r = run(
        ["tmux", "ls", "-F", "#{session_name}\t#{@wk}"],
        check=False,
    )
    if r.returncode != 0:
        return set()
    out: set[str] = set()
    for line in r.stdout.splitlines():
        if "\t" not in line:
            continue
        name, marker = line.split("\t", 1)
        if marker.strip() == "1":
            out.add(name.strip())
    return out


def _git_dirty_ahead_behind(path: Path) -> tuple[bool, int, int]:
    """(dirty, ahead, behind) for the worktree at PATH, vs the base ref.

    Tolerant of an unreadable/vanished worktree (a manual `rm -rf` of a stale
    `.worktrees/<x>`): git failures count as clean / in-sync rather than
    propagating and crashing `wk ls`, `wk switch`, or the render loops. Works
    on any path (used both for current-repo worktrees and cross-repo sessions
    in the global hub), since it's keyed only off PATH, not the cwd's repo.
    """
    status = run(["git", "-C", str(path), "status", "--porcelain"], check=False)
    dirty = bool(status.stdout.strip()) if status.returncode == 0 else False
    ahead = behind = 0
    base = os.environ.get("WK_BASE", DEFAULT_BASE)
    rev = run(
        ["git", "-C", str(path), "rev-list", "--left-right", "--count", f"{base}...HEAD"],
        check=False,
    )
    if rev.returncode == 0 and rev.stdout.strip():
        parts = rev.stdout.split()
        if len(parts) == 2:
            behind, ahead = int(parts[0]), int(parts[1])
    return dirty, ahead, behind


def workspace_status(branch: str, path: Path, sessions: set[str]) -> Workspace:
    name = session_name(branch)
    dirty, ahead, behind = _git_dirty_ahead_behind(path)
    return Workspace(
        branch=branch,
        path=path,
        session=name,
        has_session=name in sessions,
        dirty=dirty,
        ahead=ahead,
        behind=behind,
    )


def all_workspaces() -> list[Workspace]:
    # Use wk-only sessions so `has_session` reflects "wk session is running",
    # not "any tmux session with this name exists".
    sessions = wk_tmux_sessions()
    return [workspace_status(b, p, sessions) for b, p in list_wk_worktrees()]


def _repo_label(path: Path) -> str:
    """Short repo name for a worktree PATH, for the global hub's repo column.

    Fast path: wk worktrees live at `<repo>/.worktrees/<slug>`, so the repo is
    two parents up — no subprocess. Falls back to `git rev-parse` for adopted
    worktrees or a custom WK_WORKTREE_ROOT.
    """
    if path.parent.name == ".worktrees":
        return path.parent.parent.name
    r = run(["git", "-C", str(path), "rev-parse", "--show-toplevel"], check=False)
    top = r.stdout.strip() if r.returncode == 0 else ""
    return Path(top).name if top else path.name


def external_wk_sessions(local_paths: set[Path]) -> list[Workspace]:
    """Running wk sessions whose worktree is NOT in the current repo — the
    cross-repo half of the global hub. Derived live from tmux: every session
    carries @wk / @wk-branch / @wk-path, so no persistent registry is needed.
    LOCAL_PATHS are the current repo's worktree paths, excluded to avoid dupes.
    """
    r = run(
        ["tmux", "ls", "-F",
         "#{session_name}\t#{@wk}\t#{@wk-branch}\t#{@wk-path}"],
        check=False,
    )
    if r.returncode != 0:
        return []
    out: list[Workspace] = []
    for line in r.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        name, flag, branch, path = (p.strip() for p in parts[:4])
        if flag != "1" or not branch or not path:
            continue  # not a wk workspace session (e.g. the dashboard)
        p = Path(path).expanduser()
        try:
            resolved = p.resolve()
        except OSError:
            resolved = p
        if resolved in local_paths:
            continue  # this repo's own session — already in all_workspaces()
        dirty, ahead, behind = _git_dirty_ahead_behind(p)
        out.append(Workspace(
            branch=branch, path=p, session=name, has_session=True,
            dirty=dirty, ahead=ahead, behind=behind,
        ))
    return out


def hub_workspaces() -> list[Workspace]:
    """The global hub set: this repo's workspaces (running + idle) first, then
    every running wk session in OTHER repos. Outside any repo, the local half
    is empty and you still get all running agents — so the hub works anywhere.
    """
    local = all_workspaces()
    local_paths: set[Path] = set()
    for w in local:
        try:
            local_paths.add(w.path.resolve())
        except OSError:
            local_paths.add(w.path)
    return local + external_wk_sessions(local_paths)


def find_workspace(
    query: str, workspaces: Optional[list[Workspace]] = None
) -> Optional[Workspace]:
    """First workspace matching QUERY (branch / slug / full session name), or None.

    Pass an existing WORKSPACES list to avoid re-running all_workspaces() (which
    shells out per worktree); otherwise it's fetched.
    """
    ws = all_workspaces() if workspaces is None else workspaces
    return next((w for w in ws if _matches_query(query, w)), None)


def require_workspace(
    query: str, workspaces: Optional[list[Workspace]] = None
) -> Workspace:
    """find_workspace() or die — the shared "no workspace matching X" guard."""
    w = find_workspace(query, workspaces)
    if w is None:
        die(f"no workspace matching {query!r}", hint="`wk list` shows every workspace")
    return w


def in_tmux() -> bool:
    return "TMUX" in os.environ


def in_git_repo() -> bool:
    """True if the cwd is inside a git work tree, without raising the way
    `repo_root()` does. Lets commands tell "not in a repo" apart from "in a
    repo with nothing to show" — the resilience fallbacks return [] for both."""
    return run(
        ["git", "rev-parse", "--is-inside-work-tree"], check=False
    ).stdout.strip() == "true"


def attach_or_switch(session: str) -> None:
    """Attach if outside tmux, switch-client if inside."""
    if in_tmux():
        os.execvp("tmux", ["tmux", "switch-client", "-t", session])
    else:
        os.execvp("tmux", ["tmux", "attach", "-t", session])


