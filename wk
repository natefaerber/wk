def _active_pane_cwd() -> Optional[str]:
    """The cwd of the currently focused tmux pane (None if not inside tmux)."""
    if not in_tmux():
        return None
    r = run(
        ["tmux", "display-message", "-p", "#{pane_current_path}"],
        check=False,
    )
    return r.stdout.strip() or None


def _pick_zoxide() -> Optional[Path]:
    """Open zoxide's fzf-based jump list. Returns the selected dir, or None."""
    if shutil.which("zoxide") is None:
        die("zoxide not installed (https://github.com/ajeetdsouza/zoxide)")
    # `zoxide query -i` opens fzf over the frecency database. fzf does its UI
    # on the tty, prints the chosen path to stdout. capture_output=True is
    # safe — fzf reads/writes /dev/tty directly for the UI.
    r = run(["zoxide", "query", "-i"], check=False)
    if r.returncode != 0 or not r.stdout.strip():
        return None
    return Path(r.stdout.strip()).expanduser().resolve()


def _pick_yazi(starting_dir: Path) -> Optional[Path]:
    """Open yazi as a directory browser. Returns the dir yazi exited from.

    Uses yazi's --cwd-file flag: on exit, yazi writes its last cwd to the
    given file. So the user navigates to wherever, presses `q`, and we
    read out where they ended up.
    """
    if shutil.which("yazi") is None:
        die("yazi not installed (https://github.com/sxyazi/yazi)")
    import tempfile
    fd, tmpname = tempfile.mkstemp(prefix="wk-yazi-", suffix=".cwd")
    os.close(fd)
    try:
        # capture=False → yazi takes over the terminal (it's a full TUI).
        run(
            ["yazi", "--cwd-file", tmpname, str(starting_dir)],
            check=False, capture=False,
        )
        try:
            content = Path(tmpname).read_text(encoding="utf-8").strip()
        except OSError:
            return None
        return Path(content).expanduser().resolve() if content else None
    finally:
        try:
            os.unlink(tmpname)
        except OSError:
            pass


@app.command("lg-cd")
def lg_cd(
    path: Optional[str] = typer.Argument(
        None,
        help="Directory to point lazygit at. Defaults to the active pane's cwd.",
    ),
    pick: Optional[str] = typer.Option(
        None, "--pick", "-p",
        help="Pop a picker instead of taking PATH. 'zoxide' = frecency jump list, "
             "'yazi' = filesystem browser.",
    ),
    session: Optional[str] = typer.Option(
        None, "--session", "-s",
        help="Target session. Defaults to the current tmux session.",
    ),
) -> None:
    """Retarget the lazygit pane to PATH (default: active pane's cwd).

    Useful when you're working in a subrepo, submodule, or sibling repo and
    want lazygit to follow you there. Safe to call from anywhere (the agent
    pane, a shell, or `claude` via Bash) — looks up the lazygit pane by id
    that `build_session` stored as @wk-lazygit-pane.
    """
    require("tmux")

    # Resolve target dir. Priority: explicit path > interactive picker >
    # active pane's cwd > process cwd.
    if pick:
        if path:
            die("pass either PATH or --pick, not both")
        if pick == "zoxide":
            target = _pick_zoxide()
        elif pick == "yazi":
            start = (
                Path(_active_pane_cwd() or os.getcwd()).resolve()
            )
            target = _pick_yazi(start)
        else:
            die(f"unknown picker {pick!r}; expected 'zoxide' or 'yazi'")
        if target is None:
            console.print("[dim](cancelled)[/dim]")
            return
    elif path:
        target = Path(path).expanduser().resolve()
    elif in_tmux():
        target = Path(_active_pane_cwd() or os.getcwd()).resolve()
    else:
        target = Path.cwd().resolve()
    if not target.is_dir():
        die(f"not a directory: {target}")

    # Resolve target session.
    sess = session
    if sess is None and in_tmux():
        r = run(["tmux", "display-message", "-p", "#S"], check=False)
        sess = r.stdout.strip()
    if not sess:
        die("specify --session or run inside a tmux session")

    # Look up the lazygit pane id stored at build time.
    r = run(
        ["tmux", "show-options", "-v", "-t", sess, "@wk-lazygit-pane"],
        check=False,
    )
    pane_id = r.stdout.strip() if r.returncode == 0 and r.stdout.strip() else None
    if not pane_id:
        # Pre-marker sessions (or non-wk sessions) fall back to visual index.
        pane_id = f"{sess}:work.4"

    run(
        [
            "tmux", "respawn-pane", "-k",
            "-t", pane_id,
            "-c", str(target),
            *_shell_wrap(LAZYGIT_CMD),
        ]
    )
    console.print(f"[green]✓[/green] lazygit → [dim]{target}[/dim]")


@app.command()
def sidebar() -> None:
    """Passive workspace dashboard (runs inside the leftmost tmux pane).

    Auto-refreshing read-only view of all wk workspaces. Not interactive —
    use `prefix W` (popup) to actually switch. The pane is a glance,
    not an input surface.

    Reads $WK_CURRENT to mark the active workspace. Refreshes every 3s.
    """
    import time as _time
    current = os.environ.get("WK_CURRENT", "")
    refresh = float(os.environ.get("WK_SIDEBAR_REFRESH", "3"))

    while True:
        try:
            workspaces = all_workspaces()
            console.clear()
            if not workspaces:
                console.print("[dim](no workspaces)[/dim]")
                console.print()
                console.print("[dim]wk new <branch>[/dim]")
            else:
                console.print(
                    f"[bold]workspaces[/bold] [dim]({len(workspaces)})[/dim]"
                )
                console.print()
                for w in workspaces:
                    if w.session == current:
                        marker = "[green]▶[/green]"
                        name_style = "bold"
                    elif w.has_session:
                        marker = "[cyan]●[/cyan]"
                        name_style = ""
                    else:
                        marker = "[dim]·[/dim]"
                        name_style = "dim"
                    ab = (
                        f"[yellow]+{w.ahead}/-{w.behind}[/yellow]"
                        if (w.ahead or w.behind) else " " * 8
                    )
                    status = "[red]✱[/red]" if w.dirty else " "
                    name = w.branch[:24]
                    if name_style:
                        name = f"[{name_style}]{name:<24}[/{name_style}]"
                    else:
                        name = f"{name:<24}"
                    console.print(f"{marker} {name} {ab} {status}")
            console.print()
            console.print("[dim]prefix W to switch[/dim]")
            _time.sleep(refresh)
        except KeyboardInterrupt:
            return


