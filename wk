@app.command()
def cd(
    branch: Optional[str] = typer.Argument(
        None, help="Print path for BRANCH; omit to use current tmux session."
    ),
) -> None:
    """Print the worktree path (for shell `cd`).

    Usage in fish:  cd (wk cd feature-x)
    """
    require("git")
    require("tmux")
    if branch is None:
        # Infer from the current tmux session. Use in_tmux() like every other
        # command (checks $TMUX) — the old $TMUX_PANE check was an inconsistent
        # proxy and the value was discarded anyway.
        if not in_tmux():
            die("not inside tmux; pass a branch name")
        r = run(["tmux", "display-message", "-p", "#S"], check=False)
        session = r.stdout.strip()
        if not session:
            die("could not determine current tmux session; pass a branch name")
        for w in all_workspaces():
            if w.session == session:
                print(w.path)
                return
        die(f"no workspace for current session {session!r}")
    else:
        for w in all_workspaces():
            if _matches_query(branch, w):
                print(w.path)
                return
        die(f"no workspace for {branch!r}", hint="`wk list` shows every workspace")


def _pick_branch() -> Optional[str]:
    """Fzf over all local + remote branches in this repo, sorted by most
    recent commit activity. Shows a marker for branches that already have
    a wk workspace (● = running session, · = worktree but no session). The
    caller passes the chosen branch to `wk open`, which switches to an
    existing workspace if there is one or creates a new one otherwise.

    Returns the selected short branch name (origin/ prefix stripped),
    or None on cancel."""
    require("fzf")
    main = repo_root()

    # Map of branch → workspace status, so picks can show whether a wk
    # workspace already exists.
    workspaces = {w.branch: w for w in all_workspaces()}

    def _wk_marker(name: str) -> str:
        w = workspaces.get(name)
        if w is None:
            return " "
        if w.has_session:
            return "●"  # workspace + tmux session running
        return "·"      # workspace dir exists, session was closed

    def _format_line(name: str, date: str, subject: str, remote: bool) -> str:
        # Hidden field 1 = the bare branch name (what fzf returns).
        # Visible: marker + branch (padded) + date + subject + [remote]?
        display_name = (name[:32]).ljust(32)
        tag = " [remote]" if remote else ""
        visible = (
            f"{_wk_marker(name)} {display_name}  "
            f"{(date or '')[:18]:<18}  {(subject or '')[:60]}{tag}"
        )
        return f"{name}\t{visible}"

    # Local branches first, most-recent first.
    local_proc = run(
        [
            "git", "-C", str(main), "for-each-ref",
            "--sort=-committerdate",
            "--format=%(refname:short)\t%(committerdate:relative)\t%(contents:subject)",
            "refs/heads/",
        ],
        check=False,
    )
    local_lines: list[str] = []
    local_names: set[str] = set()
    if local_proc.returncode == 0:
        for ln in local_proc.stdout.splitlines():
            parts = ln.split("\t", 2)
            if len(parts) < 1 or not parts[0]:
                continue
            name = parts[0]
            local_names.add(name)
            date = parts[1] if len(parts) > 1 else ""
            subject = parts[2] if len(parts) > 2 else ""
            local_lines.append(_format_line(name, date, subject, remote=False))

    # Remote-only branches (skip ones with a local counterpart).
    remote_proc = run(
        [
            "git", "-C", str(main), "for-each-ref",
            "--sort=-committerdate",
            "--format=%(refname:short)\t%(committerdate:relative)\t%(contents:subject)",
            "refs/remotes/origin/",
        ],
        check=False,
    )
    remote_lines: list[str] = []
    if remote_proc.returncode == 0:
        for ln in remote_proc.stdout.splitlines():
            parts = ln.split("\t", 2)
            if not parts or not parts[0]:
                continue
            full = parts[0]
            if full.endswith("/HEAD"):
                continue
            short = full.removeprefix("origin/")
            if short in local_names:
                continue
            date = parts[1] if len(parts) > 1 else ""
            subject = parts[2] if len(parts) > 2 else ""
            remote_lines.append(_format_line(short, date, subject, remote=True))

    lines = local_lines + remote_lines
    if not lines:
        return None

    proc = subprocess.run(
        [
            "fzf",
            "--with-nth=2..",       # hide field 1 (the bare branch name)
            "--delimiter=\t",
            "--prompt=branch❯ ",
            "--header=●=session running  ·=worktree only  enter=open/switch  /=filter",
            "--reverse",
            "--cycle",
            "--height=100%",
            "--no-info",
        ],
        input="\n".join(lines),
        text=True,
        capture_output=True,
    )
    if proc.returncode != 0 or not proc.stdout.strip():
        return None
    return proc.stdout.strip().split("\t", 1)[0]


# --- passive views: sidebar / dashboard (+ internal renderers) ---
@app.command()
def sidebar() -> None:
    """Passive workspace dashboard (runs inside the leftmost tmux pane).

    Auto-refreshing read-only view of all wk workspaces. Not interactive —
    use `prefix W` (popup) to actually switch. The pane is a glance,
    not an input surface.

    Reads $WK_CURRENT to mark the active workspace. Refreshes every 3s
    (tune with WK_SIDEBAR_REFRESH).
    """
    current = os.environ.get("WK_CURRENT", "")
    refresh = float(os.environ.get("WK_SIDEBAR_REFRESH", "3"))

    while True:
        try:
            # Long-lived loop: drop the cwd-keyed _project_prefix cache each
            # iteration so a repo rename/move doesn't pin a stale session prefix
            # (which would make every workspace render as "no session").
            _project_prefix.cache_clear()
            workspaces = all_workspaces()
            console.clear()
            if not workspaces:
                console.print("[dim]no workspaces[/dim]")
                console.print()
                console.print("[dim]wk new <branch>[/dim]")
            else:
                console.print(
                    f"[bold]workspaces[/bold] [dim]({len(workspaces)})[/dim]"
                )
                console.print()
                for w in workspaces:
                    marker = session_marker(w, current)
                    if w.session == current:
                        name_style = "bold"
                    elif w.has_session:
                        name_style = ""
                    else:
                        name_style = "dim"
                    ab = (
                        f"[yellow]{ahead_behind(w)}[/yellow]"
                        if (w.ahead or w.behind) else " " * 8
                    )
                    status = dirty_marker(w)
                    name = w.branch[:36]
                    if name_style:
                        name = f"[{name_style}]{name:<36}[/{name_style}]"
                    else:
                        name = f"{name:<36}"
                    console.print(f"{marker} {name} {ab} {status}")
            console.print()
            console.print("[dim]prefix W to switch[/dim]")
            _time.sleep(refresh)
        except KeyboardInterrupt:
            return
        except Exception as e:
            # An always-on pane must survive a transient error (e.g. a git hiccup
            # mid-refresh) instead of dying for good. Show it and keep looping.
            console.clear()
            console.print(f"[yellow]warning:[/yellow] sidebar render failed: {e}")
            _time.sleep(refresh)


@app.command("_list-once", hidden=True)
def list_once() -> None:
    """Internal: dump one row per workspace, tab-delimited `session\\tdisplay`.
    Used by the hub's fzf --reload. Must match the picker's initial set exactly
    (the global hub) or the list jumps on reload — so it uses hub_workspaces()."""
    current = current_session()
    for w in hub_workspaces():
        print(_picker_line(w, current))


@app.command("_preview", hidden=True)
def preview(session: str = typer.Argument(...)) -> None:
    """Internal: render the sidebar preview pane for SESSION.

    Shows the task prompt (if any), recent commits, and `git status` for
    the worktree associated with SESSION. Designed to be invoked by fzf's
    --preview, so output is plain text + ANSI color (no Rich markup).

    Uses the global hub set so it resolves cross-repo sessions too — matching
    what the picker lists. (All the git below is keyed off the worktree path,
    so it works regardless of which repo SESSION lives in.)
    """
    target = next(
        (w for w in hub_workspaces() if w.session == session),
        None,
    )
    if target is None:
        print(f"(no workspace for {session!r})")
        return

    p = target.path
    print(f"\033[1m{target.branch}\033[0m  ({p})")
    print(f"+{target.ahead}/-{target.behind}  {'dirty' if target.dirty else 'clean'}"
          f"  {'session running' if target.has_session else 'no session'}")
    print()

    task_file = p / WK_MARKER_DIR / "task.md"
    if task_file.exists():
        print("\033[1m── task ──\033[0m")
        try:
            print(task_file.read_text(encoding="utf-8").strip())
        except OSError:
            pass
        print()

    print("\033[1m── recent commits ──\033[0m")
    subprocess.run(
        ["git", "-C", str(p), "log", "--color=always",
         "--pretty=format:%C(auto)%h %s %C(dim)(%ar)%C(reset)", "-15"],
        check=False,
    )
    print()
    print()
    print("\033[1m── git status ──\033[0m")
    subprocess.run(["git", "-C", str(p), "status", "-sb"], check=False)


@app.command()
def dashboard(
    refresh: Optional[float] = typer.Option(
        None, "--refresh", "-r",
        help="Refresh interval in seconds. Default 30, overridable via "
             "WK_DASHBOARD_REFRESH env var. Minimum 1s.",
    ),
) -> None:
    """Open the cross-workspace overview session.

    Creates a `wk-dashboard` tmux session running an auto-refreshing
    `wk list`. Defaults to 30s refresh; `prefix M-r` forces an immediate
    redraw via SIGUSR1.
    """
    require("tmux")
    if refresh is None:
        env_val = os.environ.get("WK_DASHBOARD_REFRESH")
        try:
            refresh = float(env_val) if env_val else 30.0
        except ValueError:
            refresh = 30.0
    refresh = max(1.0, refresh)

    if DASHBOARD_SESSION not in tmux_sessions():
        wk_path = shutil.which("wk") or sys.argv[0]
        run(
            [
                "tmux", "new-session", "-d",
                "-s", DASHBOARD_SESSION,
                "-n", "overview",
                wk_path, "_dashboard-render", "--refresh", str(refresh),
            ]
        )
        # Tag so the M-r binding can target this session's renderer.
        run(["tmux", "set-option", "-t", DASHBOARD_SESSION, "@wk-dashboard", "1"])
    attach_or_switch(DASHBOARD_SESSION)


@app.command("_dashboard-render", hidden=True)
def _dashboard_render(
    refresh: float = typer.Option(30.0, "--refresh", "-r"),
) -> None:
    """Internal: the render loop that runs inside the wk-dashboard session.

    Calls `wk list` on a clock. Handles SIGUSR1 by waking sleep early so the
    next iteration redraws immediately — bound to `prefix M-r` via pkill.
    """
    import signal as _signal

    refresh = max(1.0, refresh)
    _signal.signal(_signal.SIGUSR1, lambda *_: None)

    while True:
        try:
            # See sidebar(): drop the cwd-keyed prefix cache each iteration so a
            # repo move can't pin a stale session prefix in this long-lived loop.
            _project_prefix.cache_clear()
            console.clear()
            # Share the exact table `wk list` renders, so the dashboard and
            # the one-shot listing never drift in columns or glyphs.
            workspaces = all_workspaces()
            if not workspaces:
                console.print("[dim]no workspaces[/dim]")
            else:
                console.print(workspace_table(workspaces, current_session()))
            console.print()
            console.print(
                f"[dim]auto-refresh every {refresh:g}s · M-r to refresh now[/dim]"
            )
            _time.sleep(refresh)
        except KeyboardInterrupt:
            return
        except Exception as e:
            # Keep the dashboard pane alive through a transient error rather than
            # letting the render loop die permanently.
            console.clear()
            console.print(f"[yellow]warning:[/yellow] dashboard render failed: {e}")
            _time.sleep(refresh)


if __name__ == "__main__":
    app()
