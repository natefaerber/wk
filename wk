# tmux session construction
# ---------------------------------------------------------------------------


def _wk_bin() -> str:
    """Path to this script for sub-invocations from tmux panes."""
    return shutil.which("wk") or os.path.abspath(sys.argv[0])


def _shell_wrap(cmd: str) -> list[str]:
    """Wrap a synthetic command for tmux. Always sh — these strings are sh
    syntax (loops, inline env vars, `&&`/`||` between subshells), which fish
    won't parse. Interactive panes inherit the user's default shell elsewhere."""
    return ["sh", "-c", cmd]


# ── layout geometry ────────────────────────────────────────────────
# Sessions are built *detached* at a fixed virtual size, then tmux reshapes
# them proportionally when a client attaches. So these are the ratios that
# look right, expressed in the cols / height-percent that tmux splits take.
#
# WIDE — widescreen layout: (sidebar over shell) | agent | terminal. Four
# panes, three columns. No lazygit pane (summon it full-screen with
# `prefix M-g`). The terminal column is deliberately wide so the agent doesn't
# sprawl to ~65% of a big display — sessions are built at this virtual width
# then scaled proportionally on attach, so the cap is a ratio, not absolute
# cols.
WIDE_WINDOW_COLS = 290    # virtual width the detached session is built at
WIDE_WINDOW_ROWS = 75     # virtual height (reshaped on attach)
WIDE_SIDEBAR_COLS = 42    # left column (sidebar + shell) — ~40 cols fits branch
                          # names and `git status -sb` lines without wrapping
WIDE_TERMINAL_COLS = 90   # right-hand terminal column; wide enough that the
                          # agent lands near ~half the screen, not ~two-thirds
WIDE_SIDEBAR_PCT = 30     # sidebar's share of the left column height; the shell
                          # below it gets the larger remainder

# LAPTOP — 2-column layout for narrow displays: left column is the sidebar
# stacked over a terminal, right column is a full-height agent. No lazygit or
# separate shell pane — on a laptop they cost more width than they're worth.
LAPTOP_WINDOW_COLS = 200  # virtual width; narrower so ratios suit a laptop
LAPTOP_WINDOW_ROWS = 50
LAPTOP_LEFT_COL_COLS = 40  # sidebar/terminal column — agent takes the rest
LAPTOP_SIDEBAR_PCT = 38    # sidebar's share of the left column; the terminal
                           # beneath it gets the larger remainder

# Auto-selection threshold: a client at least this wide gets WIDE, narrower
# gets LAPTOP. Overridable via $WK_WIDE_COLS; both overridden by $WK_LAYOUT
# / --layout. 220 sits between a typical laptop (~180-210 cols) and a docked
# widescreen (260+).
WK_DEFAULT_WIDE_COLS = 220


@dataclass(frozen=True)
class LayoutProfile:
    """A named pane layout: how to build it and how to rebalance it.

    `name` is stored on the session as @wk-layout so `wk rebalance` knows
    which geometry to reset to. `build` finishes the layout from the initial
    sidebar pane; `rebalance` resets the geometry of an attached window.
    """
    name: str
    window_cols: int
    window_rows: int
    build: Callable[[str, Path, str, str], None]
    rebalance: Callable[[str], None]


# sh command that launches lazygit with wk's narrow-pane config if it exists,
# otherwise plain lazygit. If lazygit isn't installed, falls back to a shell.
LAZYGIT_CMD = (
    'WK_LG_CFG="${XDG_CONFIG_HOME:-$HOME/.config}/wk/lazygit.yml"; '
    "if command -v lazygit >/dev/null; then "
    '  if [ -f "$WK_LG_CFG" ]; then exec lazygit -ucf "$WK_LG_CFG"; '
    "  else exec lazygit; fi; "
    "else "
    '  echo "lazygit not installed — install it or use the terminal pane"; '
    "  exec ${SHELL:-sh}; "
    "fi"
)


def _build_wide(session: str, wt: Path, sidebar_id: str, agent: str) -> None:
    """Finish the widescreen layout from an existing sidebar pane:
    (sidebar over shell) | agent | terminal. Selects the agent so the user
    lands there on attach. No lazygit pane (summon it with `prefix M-g`).

        ┌────────┬──────────────────┬──────────────┐
        │ sidebar│                  │              │
        ├────────┤      agent       │   terminal   │
        │ shell  │                  │              │
        └────────┴──────────────────┴──────────────┘
    """
    # Agent — everything right of the left column.
    agent_id = run(
        [
            "tmux", "split-window", "-h",
            "-t", sidebar_id,
            "-c", str(wt),
            "-l", str(WIDE_WINDOW_COLS - WIDE_SIDEBAR_COLS),
            "-P", "-F", "#{pane_id}",
            agent,
        ]
    ).stdout.strip()

    # Terminal — carve the right-hand column off the agent (default shell).
    run(
        [
            "tmux", "split-window", "-h",
            "-t", agent_id,
            "-c", str(wt),
            "-l", str(WIDE_TERMINAL_COLS),
        ]
    )

    # Shell — split the left column below the sidebar (default shell).
    run(
        [
            "tmux", "split-window", "-v",
            "-t", sidebar_id,
            "-c", str(wt),
            "-l", f"{100 - WIDE_SIDEBAR_PCT}%",
        ]
    )

    # Land in the agent pane on attach.
    run(["tmux", "select-pane", "-t", agent_id])


def _build_laptop(session: str, wt: Path, sidebar_id: str, agent: str) -> None:
    """Finish the 2-column laptop layout from an existing sidebar pane:
    left column = sidebar over terminal, right column = full-height agent.

        ┌────────┬──────────────────────────────┐
        │ sidebar│                              │
        ├────────┤            agent             │
        │ terminal│                             │
        └────────┴──────────────────────────────┘

    No separate shell pane — the left-bottom terminal covers both.
    """
    # Agent — the entire right column. Split right of sidebar; it takes
    # everything except the left column.
    agent_width = LAPTOP_WINDOW_COLS - LAPTOP_LEFT_COL_COLS
    agent_id = run(
        [
            "tmux", "split-window", "-h",
            "-t", sidebar_id,
            "-c", str(wt),
            "-l", str(agent_width),
            "-P", "-F", "#{pane_id}",
            agent,
        ]
    ).stdout.strip()

    # Terminal — left column, bottom. Split below the sidebar (default shell).
    run(
        [
            "tmux", "split-window", "-v",
            "-t", sidebar_id,
            "-c", str(wt),
            "-l", f"{100 - LAPTOP_SIDEBAR_PCT}%",
        ]
    )

    # Land in the agent pane on attach.
    run(["tmux", "select-pane", "-t", agent_id])


def _rebalance_wide(session: str) -> None:
    """Reset the widescreen geometry on SESSION's active window.

    Targets panes by visual index, safe here because rebalance only runs on a
    fully-built, stable layout (tmux renumbers indices only while splitting).
    Visual order: 1=sidebar, 2=shell, 3=agent, 4=terminal. Resizing pane 1 sets
    the left column's width and the sidebar's share of its height; pane 4 sets
    the terminal column width. `session:.N` pins the target to SESSION, not the
    attached client's current session.
    """
    run(["tmux", "resize-pane", "-t", f"{session}:.1", "-x", str(WIDE_SIDEBAR_COLS)], check=False)
    run(["tmux", "resize-pane", "-t", f"{session}:.1", "-y", f"{WIDE_SIDEBAR_PCT}%"], check=False)
    run(["tmux", "resize-pane", "-t", f"{session}:.4", "-x", str(WIDE_TERMINAL_COLS)], check=False)


def _rebalance_laptop(session: str) -> None:
    """Reset the laptop geometry on SESSION's active window. Visual order:
    1=sidebar, 2=terminal, 3=agent — so resizing pane 1 sets both the left
    column width and the sidebar's share of its height."""
    run(["tmux", "resize-pane", "-t", f"{session}:.1", "-x", str(LAPTOP_LEFT_COL_COLS)], check=False)
    run(["tmux", "resize-pane", "-t", f"{session}:.1", "-y", f"{LAPTOP_SIDEBAR_PCT}%"], check=False)


LAYOUTS: dict[str, LayoutProfile] = {
    "wide": LayoutProfile(
        name="wide", window_cols=WIDE_WINDOW_COLS, window_rows=WIDE_WINDOW_ROWS,
        build=_build_wide, rebalance=_rebalance_wide,
    ),
    "laptop": LayoutProfile(
        name="laptop", window_cols=LAPTOP_WINDOW_COLS, window_rows=LAPTOP_WINDOW_ROWS,
        build=_build_laptop, rebalance=_rebalance_laptop,
    ),
}
# Accepted aliases for the user-facing layout name (env / flag / @wk-layout).
_LAYOUT_ALIASES = {"wide": "wide", "widescreen": "wide", "laptop": "laptop", "narrow": "laptop"}


def _client_cols() -> Optional[int]:
    """Best guess at the column width of the display we'll attach with.

    Prefers the attached tmux client's width (when run from inside tmux),
    else the controlling terminal's size. None when neither is knowable
    (e.g. a headless/cron invocation with no tty).
    """
    if in_tmux():
        r = run(["tmux", "display-message", "-p", "#{client_width}"], check=False)
        w = r.stdout.strip()
        if r.returncode == 0 and w.isdigit() and int(w) > 0:
            return int(w)
    try:
        return os.get_terminal_size().columns
    except OSError:
        return None


def resolve_profile(explicit: Optional[str] = None) -> LayoutProfile:
    """Pick a layout: explicit name (--layout) > $WK_LAYOUT > auto by width.

    Auto compares the attach display's width against $WK_WIDE_COLS (default
    220): wider → `wide`, narrower → `laptop`. When the width is unknowable
    (headless), defaults to `wide` to preserve the historical layout.
    """
    name = (explicit or os.environ.get("WK_LAYOUT", "")).strip().lower()
    if name:
        if name not in _LAYOUT_ALIASES:
            die(f"unknown layout {name!r}", hint="expected 'wide' or 'laptop'")
        return LAYOUTS[_LAYOUT_ALIASES[name]]

    try:
        threshold = int(os.environ.get("WK_WIDE_COLS") or WK_DEFAULT_WIDE_COLS)
    except ValueError:
        threshold = WK_DEFAULT_WIDE_COLS
    cols = _client_cols()
    if cols is None:
        return LAYOUTS["wide"]
    return LAYOUTS["wide"] if cols >= threshold else LAYOUTS["laptop"]


def wk_env_pairs(session: str, branch: str, wt: Path) -> list[tuple[str, str]]:
    """The WK_* environment contract exposed to every pane of a workspace.

    Single source of truth so `build_session` (which sets these via
    `new-session -e` at creation) and `_relayout-detached` (which sets them via
    `set-environment` retroactively) can't drift apart. The contract is
    documented for agents in the embedded `.wk/AGENTS.md`.
    """
    return [
        ("WK_IN_WORKSPACE", "1"),
        ("WK_SESSION", session),
        ("WK_BRANCH", branch),
        ("WK_PATH", str(wt)),
    ]


def build_session(
    session: str,
    wt: Path,
    agent: str,
    branch: Optional[str] = None,
    layout: Optional[str] = None,
) -> None:
    """Create a detached session with the wk pane layout.

    LAYOUT picks the profile ("wide" / "laptop"); None auto-selects by the
    attach display's width (see `resolve_profile`). Both build the sidebar
    first, then `profile.build` finishes the rest (lazygit is summoned on
    demand with `prefix M-g`, not a pane):

        wide (1-indexed panes)            laptop
        ┌────────┬──────────┬─────────┐   ┌────────┬─────────────────┐
        │ sidebar│          │         │   │ sidebar│                 │
        │ pane.1 │  agent   │terminal │   ├────────┤      agent      │
        ├────────┤  pane.3  │ pane.4  │   │terminal│                 │
        │ shell  │          │         │   │        │                 │
        │ pane.2 │          │         │   │        │                 │
        └────────┴──────────┴─────────┘   └────────┴─────────────────┘
    """
    wk = _wk_bin()
    profile = resolve_profile(layout)
    real_branch = branch or session

    # Mark this worktree as a wk workspace before we touch tmux — the sidebar
    # filters on this, and `wk task` may also write its own files under .wk/.
    mark_wk_workspace(wt, branch=real_branch)

    # Environment exposed to every pane in the session. Lets agents (claude,
    # etc.) detect they're inside wk and find the workspace context. tmux's
    # -e flag on new-session applies to all panes split off this session.
    env_flags: list[str] = []
    for k, v in wk_env_pairs(session, real_branch, wt):
        env_flags.extend(["-e", f"{k}={v}"])

    # Sidebar (initial pane). Starts with `wk sidebar` running.
    # `-P -F #{pane_id}` prints the new pane's stable `%NN` id; we use that
    # for subsequent splits instead of numeric indices, which tmux renumbers
    # via tree-traversal order whenever the layout changes.
    sidebar_id = run(
        [
            "tmux", "new-session", "-d",
            "-s", session,
            "-c", str(wt),
            "-x", str(profile.window_cols), "-y", str(profile.window_rows),  # reshaped on attach
            "-n", "work",
            *env_flags,
            "-P", "-F", "#{pane_id}",
            *_shell_wrap(f"WK_CURRENT={session} {wk} sidebar"),
        ]
    ).stdout.strip()

    # A successful new-session prints the new pane's %NN id. An empty/garbled
    # capture means every subsequent `-t <id>` split would target the wrong
    # pane — bail before building a broken layout (and kill whatever was made).
    if not sidebar_id.startswith("%"):
        run(["tmux", "kill-session", "-t", session], check=False)
        die(f"failed to create session {session!r} (tmux returned no pane id)")

    # If any split/option fails partway, don't leave a half-built session
    # running — callers and is_wk_workspace() would treat the zombie as a real
    # workspace. Tear it down and report.
    try:
        # Tag the session as wk-managed so tmux-resurrect filters and other
        # tools can identify it. Stored as tmux user options, readable via
        # `tmux show-options -v -t <session> @wk`.
        run(["tmux", "set-option", "-t", session, "@wk", "1"])
        run(["tmux", "set-option", "-t", session, "@wk-branch", real_branch])
        run(["tmux", "set-option", "-t", session, "@wk-path", str(wt)])
        # Record which layout this session was built with, so `wk rebalance`
        # so `wk rebalance` knows which geometry to reset to.
        run(["tmux", "set-option", "-t", session, "@wk-layout", profile.name])

        profile.build(session, wt, sidebar_id, agent)
    except Exception:
        run(["tmux", "kill-session", "-t", session], check=False)
        die(f"failed to build session {session!r}; cleaned up the partial session")


