@app.command()
def new(
    branch: str = typer.Argument(..., help="Branch name for the new workspace."),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b", help="Base ref to branch from."
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
    layout: Optional[str] = typer.Option(
        None, "--layout", "-l",
        help="Layout: 'wide' or 'laptop'. Default auto-detects from display width.",
    ),
) -> None:
    """Create a [bold]new[/bold] worktree + tmux session for BRANCH and attach.

    Errors if the branch already exists. For a forgiving "open whatever's
    there, or make it if not" command, use `wk open` instead.
    """
    require("git")
    require("tmux")

    session = session_name(branch)
    if session in tmux_sessions():
        die(f"tmux session already exists: {session}",
            hint=f"`wk switch {branch}` to attach to it")

    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=True)

    build_session(state.session, state.wt, agent_cmd(), branch=state.branch, layout=layout)
    console.print(f"[green]✓[/green] workspace [bold]{state.branch}[/bold] ready at {state.wt}")

    if not no_attach:
        attach_or_switch(state.session)


@app.command("open")
def open_cmd(
    branch: Optional[str] = typer.Argument(
        None, help="Branch name to open. Omit with --pick to fzf-pick one."
    ),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b",
        help="Base ref (used only if creating a new branch).",
    ),
    pick: bool = typer.Option(
        False, "--pick", "-p",
        help="fzf over all local + remote branches and open the one chosen.",
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
    layout: Optional[str] = typer.Option(
        None, "--layout", "-l",
        help="Layout: 'wide' or 'laptop'. Default auto-detects from display width. "
             "Applies only when building a session (ignored if one's already running).",
    ),
) -> None:
    """Open a workspace for BRANCH — a branch, a pull request, or an issue.

    Forgiving counterpart to `wk new`. For a branch name, handles every
    case:

    \b
      branch + worktree + session all exist  →  attach
      branch + worktree exist, no session    →  rebuild session, attach
      branch exists, no worktree             →  add worktree, build, attach
      branch on remote, not local            →  fetch, track, build, attach
      branch nowhere                         →  create from --base, build, attach

    Worktrees created outside `wk` (e.g. `git worktree add ...` directly)
    are recognized; their existing path is used, not wk's preferred path.

    BRANCH is also accepted as:

    \b
      a pull request   — a number (`4670`) or github PR URL → open that PR
      an issue         — a Jira link or uppercase key (`DEV-6266`) → open
                         the PR that references it, or start the work on a
                         new branch if there's no PR yet

    `wk pr` is the same PR path if you want an explicit, PR-only verb.
    Normal (lowercase) branch names never collide with the PR/issue forms.

    Already standing in a checkout you don't want recreated (a plain clone or
    a hand-made worktree)? Use `wk adopt` to wrap it in place instead.
    """
    require("git")
    require("tmux")

    if pick:
        if branch:
            die("pass either BRANCH or --pick, not both")
        branch = _pick_branch()
        if not branch:
            console.print("[dim](cancelled)[/dim]")
            return
    if not branch:
        die("missing BRANCH (or pass --pick)")

    open_ref(branch, base, no_attach, no_fetch, layout=layout)


@app.command("pr")
def pr(
    ref: str = typer.Argument(
        ...,
        help="PR number (current repo) or a github PR URL (any repo under WK_PR_REPO_ROOT).",
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
) -> None:
    """Open a workspace for the head branch of a pull request.

    \b
      wk pr 4670                                   → PR #4670 in the current repo
      wk pr https://github.com/org/repo/pull/4670  → PR #4670 in org/repo

    A bare number is looked up in the current repo. A full GitHub URL's repo
    is located under WK_PR_REPO_ROOT (default ~/_Work) by matching its
    `origin` remote, and the workspace is created there. Same-repo PRs
    become a tracking branch (the PR's own head branch), like
    `wk open <branch>`. Fork PRs — and PRs whose head branch no longer
    exists on `origin` — are fetched via `refs/pull/<n>/head` into a local
    `pr-<n>` branch.

    This is the explicit, PR-only verb. `wk open` accepts the same PR
    references (plus branches and issue keys) if you'd rather use one
    command for everything.
    """
    require("git")
    require("tmux")
    require("gh")

    pr_ref = parse_pr_ref(ref)
    if pr_ref is None:
        die(
            f"not a PR reference: {ref!r}; want a number or a github PR URL\n"
            f"  for an issue key or branch, use `wk open`"
        )
    owner, repo, number = pr_ref
    open_pr_ref(owner, repo, number, no_attach, no_fetch)


@app.command()
def adopt(
    directory: Optional[str] = typer.Argument(
        None, help="Directory to adopt. Defaults to the current directory."
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
) -> None:
    """Adopt an existing DIRECTORY as a wk workspace in place.

    The branch-centric counterpart is `wk open`, which derives a worktree
    path from a branch name and creates it if missing. `adopt` goes the
    other way: you already have a checkout on disk — a plain clone, a
    `git worktree add` you made by hand, or the main repo itself — and you
    just want wk's multi-pane session, env vars, and `.wk/` marker wrapped
    around it, without moving or recreating anything.

    The directory must be inside a git work tree; the workspace is anchored
    at that work tree's toplevel (so adopting a subdirectory adopts the
    whole checkout). The branch is read from HEAD — a detached HEAD can't be
    adopted, since the session name and `WK_BRANCH` need a branch. If a
    session of that name is already running, we just attach to it.
    """
    require("git")
    require("tmux")

    start = Path(directory).expanduser().resolve() if directory else Path.cwd().resolve()
    if not start.is_dir():
        die(f"not a directory: {start}")

    # Anchor at the work tree's toplevel, not the (possibly nested) dir the
    # user pointed at — wk workspaces are whole checkouts, and the .wk/ marker
    # and lazygit pane belong at the root.
    r = run(
        ["git", "-C", str(start), "rev-parse", "--show-toplevel"],
        check=False,
    )
    if r.returncode != 0:
        die(
            f"not inside a git work tree: {start}\n"
            f"  run `git init` there first, or use `wk open <branch>` to create one"
        )
    wt = Path(r.stdout.strip()).resolve()

    branch = run(
        ["git", "-C", str(wt), "rev-parse", "--abbrev-ref", "HEAD"]
    ).stdout.strip()
    if branch == "HEAD":
        die(
            f"{wt} is on a detached HEAD; check out a branch before adopting "
            f"(wk needs a branch for the session name and WK_BRANCH)"
        )

    session = session_name(branch)
    if session in tmux_sessions():
        console.print(f"[dim]session running; attaching[/dim]")
    else:
        build_session(session, wt, agent_cmd(), branch=branch)
        console.print(f"[green]✓[/green] adopted [bold]{branch}[/bold] at {wt}")

    if not no_attach:
        attach_or_switch(session)


# The headless (`--auto`) task command, shared by `wk task --auto` and
# `wk task-retry`. Runs from the worktree cwd, so the `.wk/...` paths resolve.
# Writes a `.wk/done` sentinel FILE when claude exits (not a log marker) —
# task-status keys "done" off the file's existence, which can't be spoofed by
# the task's own output echoing a magic string. `read -n 1` keeps the pane open
# for review.
_AUTO_TASK_CMD = (
    "claude -p \"$(cat .wk/task.md)\" 2>&1 | tee .wk/output.md; "
    "touch .wk/done; "
    # Report back to the orchestrator that spawned us, if any. @wk-task-orch is
    # set on this session by `wk task`; reading it at completion (not spawn)
    # avoids the set-option race. display-message surfaces in the orchestrator's
    # status line; the sidebar's ✓ glyph is the persistent signal. No daemon.
    'orch=$(tmux show-options -qv @wk-task-orch 2>/dev/null); '
    '[ -n "$orch" ] && tmux display-message -t "$orch" '
    '"wk: task ${WK_BRANCH:-?} done — wk task-merge ${WK_BRANCH:-} --rm" '
    '2>/dev/null; '
    "echo; echo '── task complete ── press any key to close ──'; "
    "read -n 1"
)


# --- orchestrator: task / task-status / -output / -merge / -cancel / -retry ---
@app.command()
def task(
    prompt: str = typer.Argument(..., help="The task description / prompt for Claude."),
    branch: Optional[str] = typer.Option(
        None, "--branch", "-B",
        help="Branch name (skips AI naming). If omitted, Claude picks one.",
    ),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b", help="Base ref to branch from."
    ),
    auto: bool = typer.Option(
        False, "--auto",
        help="Non-interactive: run `claude -p`, stream output to .wk/output.md, exit when done.",
    ),
    yes: bool = typer.Option(
        False, "--yes", "-y",
        help="Skip the confirm-branch-name prompt.",
    ),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
    no_attach: bool = typer.Option(
        False, "--no-attach",
        help="Don't attach the tmux session (still creates it).",
    ),
) -> None:
    """Create a workspace and kick off Claude Code with [bold]PROMPT[/bold].

    The spawn half of the orchestrator pattern: names a branch (Claude picks
    one from the prompt unless you pass --branch), builds the workspace, and
    launches the agent already primed with PROMPT. Interactive by default —
    you attach and watch. With --auto it runs headless (`claude -p`), streams
    to `.wk/output.md`, and exits when done, so you can fan out several at
    once and check back with `wk task-status` / `wk task-output`, then fold
    the result in with `wk task-merge`. Run it from an orchestrator branch
    (main/master/…), never from inside a task workspace — that's recursion.
    """
    require("git")
    require("tmux")
    require("claude")

    # Pick a branch name. Use the explicit one if given, otherwise ask Claude,
    # falling back to a deterministic slug.
    if branch is not None:
        if not _BRANCH_RE.match(branch):
            die(f"invalid branch name {branch!r}; want [a-z][a-z0-9-]{{2,59}}")
        source = "user"
    else:
        console.print("[dim]picking a branch name…[/dim]")
        branch, source = pick_branch_name(prompt)

    console.print(f"branch: [bold]{branch}[/bold] [dim]({source})[/dim]")

    if not yes and source != "user":
        # Let the user override before we touch git.
        # typer.prompt returns the user's input; empty = accept default.
        chosen = typer.prompt(
            "use this name? [enter to accept, or type a different name]",
            default=branch,
            show_default=False,
        ).strip() or branch
        if chosen != branch:
            if not _BRANCH_RE.match(chosen):
                die(f"invalid branch name {chosen!r}; want [a-z][a-z0-9-]{{2,59}}")
            branch = chosen

    session = session_name(branch)
    if session in tmux_sessions():
        die(f"tmux session already exists: {session}",
            hint=f"`wk switch {branch}` to attach to it")

    # Create the worktree (strict: error if branch already exists).
    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=True)
    wt = state.wt

    # Write the task file. This is the durable record of what the workspace
    # is for, surfaced in the sidebar and readable by `claude` later.
    # `mark_wk_workspace` creates the .wk/ dir and its .gitignore.
    mark_wk_workspace(wt, branch=branch)
    task_file = wt / WK_MARKER_DIR / "task.md"
    task_file.write_text(prompt.strip() + "\n", encoding="utf-8")

    # Build the session. Agent command depends on --auto.
    if auto:
        build_session(session, wt, " ".join(_shell_wrap(_AUTO_TASK_CMD)), branch=branch)
    else:
        # Interactive: launch claude with the prompt as a positional arg so
        # it's pre-filled in the input buffer. Claude handles the launch
        # timing itself — no send-keys race condition.
        # We use shell-quoting via shlex for safety against unusual chars.
        agent = f"claude {shlex.quote(prompt.strip())}"
        build_session(session, wt, agent, branch=branch)

    # Tag the session as a task workspace so the sidebar can mark it.
    run(["tmux", "set-option", "-t", session, "@wk-task", "1"])
    run(["tmux", "set-option", "-t", session, "@wk-task-prompt", prompt.strip()[:200]])
    # Record who spawned us so the auto-task command can report completion back.
    # Captured from the current session (the orchestrator); empty when `wk task`
    # is run outside a wk session, in which case the child stays silent.
    orch_session = current_session()
    if orch_session:
        run(["tmux", "set-option", "-t", session, "@wk-task-orch", orch_session])

    console.print(f"[green]✓[/green] task workspace [bold]{branch}[/bold] ready")
    console.print(f"  [dim]task file: {task_file}[/dim]")
    if auto:
        console.print(f"  [dim]output:    {wt}/.wk/output.md[/dim]")

    if not no_attach:
        attach_or_switch(session)


# ---------------------------------------------------------------------------
# orchestrator support — status / output / merge for spawned task workspaces
# ---------------------------------------------------------------------------


# Name of the sentinel file `_AUTO_TASK_CMD` touches when claude exits.
# task-status keys "done" off its existence (robust to the task's own output).
_TASK_DONE_MARKER = "done"


def _is_task_workspace_session(session: str) -> bool:
    """Did `wk task` create this session? (checks the @wk-task user option)."""
    r = run(
        ["tmux", "show-options", "-v", "-t", session, "@wk-task"],
        check=False,
    )
    return r.returncode == 0 and r.stdout.strip() == "1"


def _tail_text(path: Path, max_bytes: int = 8192) -> str:
    """Read the last ~max_bytes of a file; useful for status snapshots
    without slurping multi-MB logs."""
    try:
        with path.open("rb") as f:
            f.seek(0, os.SEEK_END)
            size = f.tell()
            f.seek(max(0, size - max_bytes), os.SEEK_SET)
            return f.read().decode("utf-8", errors="replace")
    except OSError:
        return ""


@dataclass
class TaskStatus:
    branch: str
    session: str
    has_session: bool
    is_task: bool
    state: str  # running | done | failed | idle
    ahead: int
    behind: int
    dirty: bool
    output_path: Path
    output_size: int
    last_line: Optional[str]
    prompt_excerpt: Optional[str]


def _task_status(w: Workspace) -> TaskStatus:
    """Build a status snapshot for one workspace."""
    is_task = w.has_session and _is_task_workspace_session(w.session)
    output_path = w.path / WK_MARKER_DIR / "output.md"
    output_size = output_path.stat().st_size if output_path.exists() else 0
    done = (w.path / WK_MARKER_DIR / _TASK_DONE_MARKER).exists()
    last_line: Optional[str] = None
    state = "idle"

    if output_size > 0:
        tail = _tail_text(output_path)
        # Last non-empty line, stripped of ANSI/control chars best-effort.
        lines = [ln.rstrip() for ln in tail.splitlines() if ln.strip()]
        last_line = lines[-1] if lines else None

    # The `.wk/done` sentinel is the source of truth for completion; it can't be
    # faked by the task's own output (unlike grepping for a marker string).
    if done:
        state = "done"
    elif output_size > 0:
        state = "running" if w.has_session else "failed"  # session gone mid-run
    elif is_task and w.has_session:
        # Auto task with no output yet, or interactive task — call it running.
        state = "running"
    elif is_task and not w.has_session:
        state = "idle"  # task workspace whose session got killed pre-output

    prompt_excerpt: Optional[str] = None
    r = run(
        ["tmux", "show-options", "-v", "-t", w.session, "@wk-task-prompt"],
        check=False,
    )
    if r.returncode == 0 and r.stdout.strip():
        prompt_excerpt = r.stdout.strip().strip('"')

    return TaskStatus(
        branch=w.branch,
        session=w.session,
        has_session=w.has_session,
        is_task=is_task,
        state=state,
        ahead=w.ahead,
        behind=w.behind,
        dirty=w.dirty,
        output_path=output_path,
        output_size=output_size,
        last_line=last_line,
        prompt_excerpt=prompt_excerpt,
    )


_STATE_STYLE = {
    "running": "yellow",
    "done": "green",
    "failed": "red",
    "idle": "dim",
}


@app.command("task-status")
def task_status(
    branch: Optional[str] = typer.Argument(
        None, help="Specific workspace; omit for a table of all task workspaces."
    ),
    all_workspaces_flag: bool = typer.Option(
        False, "--all", "-a",
        help="Include non-task wk workspaces too (default: task workspaces only).",
    ),
) -> None:
    """Show status of `wk task` workspaces.

    Designed for orchestrator polling: tells you which tasks are still
    running, which finished, which crashed, and what each one last said.
    """
    require("git")
    require("tmux")
    workspaces = all_workspaces()
    if branch:
        targets = [require_workspace(branch, workspaces)]
    else:
        targets = workspaces

    rows = [_task_status(w) for w in targets]
    if not all_workspaces_flag and not branch:
        rows = [r for r in rows if r.is_task]
    if not rows:
        console.print("[dim](no task workspaces)[/dim]")
        return

    if branch:
        # Detailed single-workspace render.
        s = rows[0]
        style = _STATE_STYLE.get(s.state, "white")
        console.print(f"[bold]{s.branch}[/bold]  [{style}]{s.state}[/{style}]")
        console.print(f"  session:  {s.session}  [{'alive' if s.has_session else 'gone'}]")
        console.print(f"  +{s.ahead}/-{s.behind}   {'dirty' if s.dirty else 'clean'}")
        if s.prompt_excerpt:
            console.print(f"  prompt:   [dim]{s.prompt_excerpt}[/dim]")
        if s.output_size:
            console.print(f"  output:   {s.output_path} ({s.output_size} bytes)")
            if s.last_line:
                console.print(f"  last:     [dim]{s.last_line[:160]}[/dim]")
        return

    table = Table(show_header=True, header_style="bold")
    table.add_column("branch")
    table.add_column("state")
    table.add_column("session")
    table.add_column("±", justify="right")
    table.add_column("dirty", justify="center")
    table.add_column("last output")
    for s in rows:
        style = _STATE_STYLE.get(s.state, "white")
        table.add_row(
            s.branch[:36],
            f"[{style}]{s.state}[/{style}]",
            "●" if s.has_session else "·",
            f"+{s.ahead}/-{s.behind}",
            "✱" if s.dirty else " ",
            (s.last_line or "")[:80],
        )
    console.print(table)


@app.command("task-output")
def task_output(
    branch: str = typer.Argument(..., help="Branch / session of the task workspace."),
    tail: Optional[int] = typer.Option(
        None, "--tail", "-n", help="Show only the last N lines."
    ),
    follow: bool = typer.Option(
        False, "--follow", "-f", help="Stream new output (tail -f style)."
    ),
) -> None:
    """Dump a `--auto` task workspace's `.wk/output.md` (the headless agent's log).

    The way to read what a headless task did without attaching its session:
    `--auto` tasks stream the agent's stdout to `.wk/output.md`, and this
    prints it. `--tail N` shows only the last N lines; `--follow` streams new
    output (`tail -f`) so you can watch a run in progress. Use `wk task-status`
    first to see which tasks are running, done, or failed.
    """
    require("git")
    target = require_workspace(branch)
    output_path = target.path / WK_MARKER_DIR / "output.md"
    if not output_path.exists():
        die(f"no output yet at {output_path}",
            hint="`wk task-status` shows which tasks have produced output")

    if follow:
        # Hand off to `tail -f` so we don't reimplement the inotify dance.
        os.execvp("tail", ["tail", "-f", str(output_path)])
    if tail is not None:
        # Read last N lines without slurping the whole file.
        text = _tail_text(output_path, max_bytes=max(8192, tail * 200))
        lines = text.splitlines()
        sys.stdout.write("\n".join(lines[-tail:]) + "\n")
        return
    sys.stdout.write(output_path.read_text(encoding="utf-8", errors="replace"))


@app.command("task-merge")
def task_merge(
    branch: str = typer.Argument(..., help="Task branch to merge into the current workspace's branch."),
    squash: bool = typer.Option(
        False, "--squash", help="Squash-merge (one commit) instead of --no-ff merge."
    ),
    ff_only: bool = typer.Option(
        False, "--ff-only", help="Fast-forward-only merge (fail if not a fast-forward)."
    ),
    no_commit: bool = typer.Option(
        False, "--no-commit",
        help="Merge but don't commit (lets you inspect before finalizing).",
    ),
    into: Optional[str] = typer.Option(
        None, "--into",
        help="Orchestrator workspace to merge into (branch / session / slug). "
             "Default: the current tmux session. Pass this to merge from "
             "outside the orchestrator session (e.g. headless).",
    ),
    rm: bool = typer.Option(
        False, "--rm",
        help="After a successful merge, tear down the task workspace "
             "(worktree + session). The branch is deleted only if it's "
             "ancestor-merged into the orchestrator branch.",
    ),
) -> None:
    """Merge a task branch into an orchestrator workspace's branch.

    Defaults to the *current* wk session as the orchestrator; pass `--into`
    to target another (which also lets you run this from outside any session).
    The merge happens in the orchestrator's worktree, against its branch.
    Errors if either side has uncommitted changes. With `--rm`, the merged
    task workspace is torn down in one step.
    """
    require("git")
    workspaces = all_workspaces()
    # Resolve the orchestrator: an explicit --into target, else the current
    # session. Resolving by query (not bare #S) is what lets `--into` be fired
    # from anywhere — the deferred merge-when-done latch and agent callers need
    # this, and it sidesteps the "#S is the child, not the orchestrator" bug.
    if into:
        orch = require_workspace(into, workspaces)
    else:
        if not in_tmux():
            die("run from inside a wk session (the orchestrator workspace)",
                hint="or pass `--into <orchestrator>` to target one explicitly")
        orch_session = run(["tmux", "display-message", "-p", "#S"]).stdout.strip()
        orch = next((w for w in workspaces if w.session == orch_session), None)
        if orch is None:
            die("current tmux session isn't a wk workspace",
                hint="`wk relayout` converts the current session into one, "
                     "or pass `--into <orchestrator>`")
    if rm and (squash or no_commit):
        die("--rm needs a finalized merge; it can't combine with "
            "--squash or --no-commit")
    task = require_workspace(branch, workspaces)
    if task.session == orch.session:
        die("can't merge a workspace into itself")
    if task.dirty:
        die(
            f"task workspace [bold]{task.branch}[/bold] has uncommitted changes; "
            "commit or stash before merging"
        )
    if orch.dirty:
        die(
            f"orchestrator workspace [bold]{orch.branch}[/bold] has uncommitted changes; "
            "commit or stash before merging"
        )

    cmd = ["git", "-C", str(orch.path), "merge"]
    if ff_only:
        cmd.append("--ff-only")
    elif squash:
        cmd.append("--squash")
    else:
        cmd.append("--no-ff")
    if no_commit and not squash:
        cmd.append("--no-commit")
    cmd.append(task.branch)

    console.print(f"[dim]$ {' '.join(cmd)}[/dim]")
    result = run(cmd, check=False, capture=False)
    if result.returncode != 0:
        die(
            f"merge failed (rc={result.returncode}); resolve in {orch.path}"
        )
    console.print(
        f"[green]✓[/green] merged [bold]{task.branch}[/bold] → "
        f"[bold]{orch.branch}[/bold]"
    )
    if squash:
        console.print(
            f"[dim]squashed — commit manually in {orch.path}[/dim]"
        )

    if rm:
        # Tear down the merged task. Delete the branch only if it's genuinely
        # ancestor-merged into the orchestrator branch — checking against the
        # orchestrator branch specifically, not the main checkout's HEAD (which
        # `wk rm`'s plain `-d` would, and wrongly refuse). When confirmed merged,
        # the force delete is safe; otherwise keep the branch and only drop the
        # worktree, so no committed-but-unmerged work is ever silently lost.
        main = repo_root()
        merged = run(
            ["git", "-C", str(main), "branch", "--merged", orch.branch,
             "--format=%(refname:short)"],
            check=False,
        )
        is_merged = task.branch in merged.stdout.split()
        _do_rm(task, main, force=is_merged, keep_branch=not is_merged)
        if is_merged:
            console.print(
                f"[green]✓[/green] removed task workspace [bold]{task.branch}[/bold]"
            )
        else:
            console.print(
                f"[yellow]warning:[/yellow] removed worktree but kept branch "
                f"[bold]{task.branch}[/bold] (not ancestor-merged into "
                f"{orch.branch})"
            )


@app.command("task-cancel")
def task_cancel(
    branch: str = typer.Argument(..., help="Task workspace to cancel."),
) -> None:
    """Stop a running task's agent without destroying anything.

    Kills the task's tmux session (which terminates the `claude` process) but
    keeps the worktree, `.wk/task.md`, and any partial output on disk. Use this
    when a task is wedged or going the wrong way: unlike `wk rm` it loses no
    work, and you can inspect the result or re-run it with `wk task-retry`.
    """
    require("git")
    require("tmux")
    target = require_workspace(branch)
    if target.has_session:
        run(["tmux", "kill-session", "-t", target.session], check=False)
        console.print(
            f"[green]✓[/green] cancelled [bold]{target.branch}[/bold] "
            f"[dim](worktree kept; `wk task-retry {target.branch}` to re-run, "
            f"`wk rm {target.branch}` to discard)[/dim]"
        )
    else:
        console.print(
            f"[dim]no running session for {target.branch}; nothing to cancel[/dim]"
        )


@app.command("task-retry")
def task_retry(
    branch: str = typer.Argument(..., help="Task workspace to re-run."),
    no_attach: bool = typer.Option(
        False, "--no-attach", help="Don't attach the rebuilt session."
    ),
) -> None:
    """Re-run a task's agent against its existing `.wk/task.md`, in place.

    For a task that crashed or finished unsatisfactorily: reuses the same
    worktree and prompt, rebuilds the headless (`--auto`) session, and clears
    the previous run's `output.md` / `done` markers so status reflects the fresh
    run. The branch and its commits are left untouched — retry re-runs the
    agent, it does not reset your code.
    """
    require("git")
    require("tmux")
    require("claude")
    target = require_workspace(branch)
    task_file = target.path / WK_MARKER_DIR / "task.md"
    if not task_file.exists():
        die(
            f"no task file at {task_file} — is {target.branch!r} a "
            f"`wk task` workspace?"
        )
    prompt = task_file.read_text(encoding="utf-8").strip()

    # Kill any running session and clear the prior run's markers so task-status
    # reflects the fresh run rather than the stale "done"/output.
    if target.has_session:
        run(["tmux", "kill-session", "-t", target.session], check=False)
    for marker in ("output.md", _TASK_DONE_MARKER):
        p = target.path / WK_MARKER_DIR / marker
        if p.exists():
            p.unlink()

    session = session_name(target.branch)
    build_session(
        session, target.path, " ".join(_shell_wrap(_AUTO_TASK_CMD)),
        branch=target.branch,
    )
    run(["tmux", "set-option", "-t", session, "@wk-task", "1"])
    run(["tmux", "set-option", "-t", session, "@wk-task-prompt", prompt[:200]])
    console.print(f"[green]✓[/green] re-running [bold]{target.branch}[/bold]")
    console.print(f"  [dim]output: {target.path}/.wk/output.md[/dim]")
    if not no_attach:
        attach_or_switch(session)


def _pick_restore_targets(
    candidates: list[tuple[str, Path]],
) -> Optional[list[tuple[str, Path]]]:
    """Fzf multi-select over restorable (branch, path) pairs.

    Prepends a synthetic `<all>` row so a single enter on it picks
    everything. Otherwise, tab marks individual rows and enter restores
    just the marked set (or the highlighted row if none are marked).
    Returns None on cancel.
    """
    if shutil.which("fzf") is None:
        # No fzf → fall back to "restore all", matching the prior behavior.
        return candidates

    all_marker = "<all>"
    lines: list[str] = [f"{all_marker}\t<all {len(candidates)} workspace(s)>"]
    for b, p in candidates:
        lines.append(f"{b}\t{b[:40]:<40}  {p}")

    proc = subprocess.run(
        [
            "fzf",
            "--with-nth=2..",
            "--delimiter=\t",
            "--multi",
            "--no-info",
            "--reverse",
            "--cycle",
            "--height=100%",
            "--prompt=restore❯ ",
            "--header=tab=mark  enter=restore selected (or highlighted)  <all>=everything",
        ],
        input="\n".join(lines),
        text=True,
        capture_output=True,
    )
    if proc.returncode != 0 or not proc.stdout.strip():
        return None

    picked: list[str] = [
        ln.split("\t", 1)[0] for ln in proc.stdout.strip().splitlines()
    ]
    if all_marker in picked:
        return candidates
    pick_set = set(picked)
    return [(b, p) for b, p in candidates if b in pick_set]


# --- session management: restore / relayout / refresh-agents ---
@app.command()
def restore(
    branch: Optional[str] = typer.Argument(
        None, help="Branch to restore. Omit to restore all worktrees missing a session."
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
    list_only: bool = typer.Option(
        False, "--list", "-l",
        help="Print what would be restored and exit. No side effects.",
    ),
    all_targets: bool = typer.Option(
        False, "--all", "-a",
        help="Restore every missing session without prompting (skips the picker).",
    ),
) -> None:
    """Rebuild tmux session(s) for existing worktree(s).

    Use after a reboot or `tmux kill-server` to re-create the wk layout
    on top of worktrees that still exist on disk. No git operations; the
    branch must already have a worktree.

    With no argument, on a TTY with multiple missing sessions, pops an fzf
    multi-select picker so you can choose a subset. Pass `--all` to skip the
    picker, or `--list` to just see what would be restored.
    """
    require("git")
    require("tmux")

    sessions = tmux_sessions()
    worktrees = list_worktrees()
    if not worktrees:
        die("no worktrees to restore")

    targets: list[tuple[str, Path]] = []
    if branch is None:
        candidates = [
            (b, p) for b, p in worktrees if session_name(b) not in sessions
        ]
        if not candidates:
            console.print("[dim]all worktrees already have sessions[/dim]")
            return

        if list_only:
            for b, p in candidates:
                console.print(f"  [bold]{b}[/bold]  [dim]{p}[/dim]")
            console.print(f"[dim]{len(candidates)} worktree(s) without a session[/dim]")
            return

        if all_targets or len(candidates) == 1 or not sys.stdin.isatty():
            targets = candidates
        else:
            picked = _pick_restore_targets(candidates)
            if picked is None:
                console.print("[dim](cancelled)[/dim]")
                return
            if not picked:
                console.print("[dim]nothing selected[/dim]")
                return
            targets = picked
    else:
        match = next(
            ((b, p) for b, p in worktrees if _query_matches(branch, b)),
            None,
        )
        if match is None:
            die(f"no worktree for {branch!r}")
        b, p = match
        if list_only:
            if session_name(b) in sessions:
                console.print(f"  [dim]{b}  (already has session)[/dim]")
            else:
                console.print(f"  [bold]{b}[/bold]  [dim]{p}[/dim]")
            return
        if session_name(b) in sessions:
            die(f"session {session_name(b)} already exists; use `wk switch` to attach")
        targets = [match]

    rebuilt: list[str] = []
    for b, p in targets:
        s = session_name(b)
        console.print(f"[dim]restoring {b}…[/dim]")
        build_session(s, p, agent_cmd(), branch=b)
        rebuilt.append(s)

    console.print(f"[green]✓[/green] restored {len(rebuilt)} workspace(s)")

    if not no_attach and len(rebuilt) == 1:
        attach_or_switch(rebuilt[0])


@app.command()
def relayout(
    force: bool = typer.Option(
        False, "--force", "-f",
        help="Skip confirmation when the current session isn't tagged as wk.",
    ),
    layout: Optional[str] = typer.Option(
        None, "--layout", "-l",
        help="Layout profile: 'wide' or 'laptop'. Default auto-detects from "
             "the display width (see CHEATSHEET).",
    ),
) -> None:
    """Rebuild the wk pane layout in the current tmux session's active window.

    Useful when a layout has been mangled by hand, when you've docked/undocked
    and want the other layout, or to convert the current tmux session into a
    wk workspace. (Sibling "make this wk" verbs: `wk adopt` wraps a *directory*
    in place; `wk open` builds one from a *branch* name — reach for relayout
    only to fix/convert/reshape the session you're already in.)
    Kills every other pane in the active window and respawns the active pane as
    the sidebar, then re-runs the same split sequence `wk open` uses. The
    session keeps its name.

    The destructive work runs in a detached process — same trick `wk rm` uses
    for self-removal — because respawning the pane that's running this command
    would otherwise kill it mid-execution.
    """
    require("tmux")
    require("git")
    if not in_tmux():
        die("not inside tmux; run this from within the session you want to relayout")

    info = run(
        ["tmux", "display-message", "-p",
         "#S\t#{pane_id}\t#{window_id}\t#{pane_current_path}"]
    ).stdout.strip()
    parts = info.split("\t")
    if len(parts) < 4:
        die(f"could not parse tmux state: {info!r}")
    session, cur_pane_id, win_id, cur_path = parts

    is_wk = run(
        ["tmux", "show-options", "-v", "-t", session, "@wk"], check=False
    ).stdout.strip() == "1"

    # Prefer the canonical @wk-path / @wk-branch the session was tagged with;
    # otherwise infer from the active pane's cwd + git HEAD.
    wt_str = run(
        ["tmux", "show-options", "-v", "-t", session, "@wk-path"], check=False
    ).stdout.strip()
    branch = run(
        ["tmux", "show-options", "-v", "-t", session, "@wk-branch"], check=False
    ).stdout.strip()

    wt = Path(wt_str).expanduser() if wt_str else Path(cur_path)
    if not wt.is_dir():
        die(f"working tree {wt} does not exist")
    if not branch:
        r = run(
            ["git", "-C", str(wt), "rev-parse", "--abbrev-ref", "HEAD"], check=False
        )
        if r.returncode != 0 or not r.stdout.strip() or r.stdout.strip() == "HEAD":
            die(f"could not determine branch for {wt}")
        branch = r.stdout.strip()

    if not is_wk and not force:
        console.print(
            f"[yellow]warning:[/yellow] session [bold]{session}[/bold] is not a wk session"
        )
        console.print(
            f"  will convert: branch=[bold]{branch}[/bold]  path=[dim]{wt}[/dim]"
        )
        if not typer.confirm("Proceed?", default=True):
            raise typer.Exit(0)

    # Resolve the profile HERE, while a client is attached and its width is
    # knowable — the detached worker has no client to auto-detect from, so we
    # hand it the concrete name.
    profile = resolve_profile(layout)

    wk_bin = _wk_bin()
    subprocess.Popen(
        [
            wk_bin, "_relayout-detached",
            "--session", session,
            "--pane", cur_pane_id,
            "--window", win_id,
            "--wt", str(wt),
            "--branch", branch,
            "--layout", profile.name,
        ],
        start_new_session=True,  # survive the pane respawn that kills our shell
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    # No success message — this pane is about to be respawned.


@app.command("_relayout-detached", hidden=True)
def _relayout_detached(
    session: str = typer.Option(...),
    pane: str = typer.Option(..., help="Pane id (%NN) to keep and respawn as sidebar."),
    window: str = typer.Option(..., help="Window id (@NN) to relayout."),
    wt: str = typer.Option(..., help="Worktree path."),
    branch: str = typer.Option(..., help="Branch name."),
    layout: str = typer.Option("wide", help="Resolved layout name ('wide'/'laptop')."),
) -> None:
    """Internal: do the destructive layout rebuild for `wk relayout` from a
    process detached from the pane being respawned."""
    require("tmux")
    wt_path = Path(wt)
    wk = _wk_bin()
    profile = resolve_profile(layout)

    # We run detached with stdout/stderr at /dev/null, and our FIRST act below is
    # destructive (`kill-pane -a` nukes every other pane in the window). If a
    # later step raises, the user is left with a mangled single-pane window and
    # no diagnostic anywhere — so log any failure to a stable file, mirroring
    # `_rm-detached`. (repo_root() resolves from the worktree we're relaying out.)
    try:
        # Mark the worktree and tag the session so subsequent wk commands
        # (sidebar, switch, etc.) recognize it.
        mark_wk_workspace(wt_path, branch=branch)
        run(["tmux", "set-option", "-t", session, "@wk", "1"])
        run(["tmux", "set-option", "-t", session, "@wk-branch", branch])
        run(["tmux", "set-option", "-t", session, "@wk-path", str(wt_path)])
        run(["tmux", "set-option", "-t", session, "@wk-layout", profile.name])

        # Push WK_* into the session environment so newly-spawned panes inherit
        # them. (build_session uses `-e` on new-session for the same effect at
        # creation time; we can't do that retroactively, so set-environment is
        # the equivalent for an existing session.)
        for k, v in wk_env_pairs(session, branch, wt_path):
            run(["tmux", "set-environment", "-t", session, k, v])

        # Kill every pane in the target window except the one we're going to
        # respawn as the sidebar.
        run(["tmux", "kill-pane", "-a", "-t", pane], check=False)

        # Match build_session's window naming.
        run(["tmux", "rename-window", "-t", window, "work"], check=False)

        # Respawn the surviving pane as the sidebar. -k force-kills the existing
        # process (our parent shell, plus its now-exited wk caller).
        run(
            [
                "tmux", "respawn-pane", "-k",
                "-t", pane,
                "-c", str(wt_path),
                *_shell_wrap(f"WK_CURRENT={session} {wk} sidebar"),
            ]
        )

        profile.build(session, wt_path, pane, agent_cmd())
    except Exception:
        try:
            logdir = repo_root() / ".git"
        except Exception:
            logdir = wt_path
        _log_detached_failure(logdir, f"_relayout-detached {session}")
        raise


@app.command()
def rebalance() -> None:
    """Reset the current window's pane sizes to the wk layout's defaults.

    Run from inside a wk session after dragging pane borders around. Reads
    the session's @wk-layout tag to apply the right geometry (the widescreen
    and laptop layouts have different target sizes). Bound to `prefix M-w`.
    """
    require("tmux")
    if not in_tmux():
        die("not inside tmux; run `wk rebalance` from within a wk session")
    session = run(["tmux", "display-message", "-p", "#S"]).stdout.strip()
    # Refuse on a non-wk session: M-w fires globally, and resizing a plain
    # tmux session's panes to wk's column widths would mangle it.
    is_wk = run(
        ["tmux", "show-options", "-v", "-t", session, "@wk"], check=False
    ).stdout.strip()
    if is_wk != "1":
        die(f"{session!r} isn't a wk session; nothing to rebalance",
            hint="run `wk rebalance` from inside a wk workspace")
    name = run(
        ["tmux", "show-options", "-v", "-t", session, "@wk-layout"], check=False
    ).stdout.strip()
    profile = LAYOUTS.get(name, LAYOUTS["wide"])
    profile.rebalance(session)


@app.command("refresh-agents")
def refresh_agents(
    branch: Optional[str] = typer.Argument(
        None, help="Workspace to refresh. Omit for the current session."
    ),
    all_workspaces_flag: bool = typer.Option(
        False, "--all", "-a", help="Refresh every wk workspace."
    ),
) -> None:
    """Regenerate `.wk/AGENTS.md` (and `.wk/ORCHESTRATOR.md` when applicable)
    in place. Overwrites existing files — useful after `wk` itself ships
    updated agent docs.

    With no arguments, refreshes the current tmux session's workspace.
    Pass a branch name to target a specific one, or `--all` for every wk
    workspace this repo knows about.
    """
    require("git")
    require("tmux")
    workspaces = all_workspaces()
    if all_workspaces_flag:
        targets = workspaces
    elif branch:
        targets = [
            w for w in workspaces
            if _matches_query(branch, w)
        ]
        if not targets:
            die(f"no workspace matching {branch!r}", hint="`wk list` shows every workspace")
    else:
        if not in_tmux():
            die("not inside tmux; pass a branch name or --all")
        r = run(["tmux", "display-message", "-p", "#S"], check=False)
        sess = r.stdout.strip()
        targets = [w for w in workspaces if w.session == sess]
        if not targets:
            die(f"current session {sess!r} isn't a wk workspace")

    refreshed = 0
    for w in targets:
        wrote_agents = _write_agents_md(w.path, force=True)
        wrote_orch = _write_orchestrator_md(w.path, w.branch, force=True)
        parts: list[str] = []
        if wrote_agents:
            parts.append("AGENTS.md")
        if wrote_orch:
            parts.append("ORCHESTRATOR.md")
        if parts:
            refreshed += 1
            console.print(
                f"[green]✓[/green] {w.branch}: refreshed {', '.join(parts)}"
            )
        else:
            console.print(f"[dim]·[/dim] {w.branch}: no agent docs apply")
    if all_workspaces_flag:
        console.print(
            f"[dim]refreshed {refreshed}/{len(targets)} workspace(s)[/dim]"
        )


