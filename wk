from rich.table import Table

# Single source of truth for the CLI version. Kept in lockstep with the git
# release tag and the plugin manifests (`.claude-plugin/*.json`) — the release
# workflow fails if they don't all match. Surfaced via `wk --version` and the
# `wk version` command.
__version__ = "0.9.0"

app = typer.Typer(
    add_completion=False,
    no_args_is_help=True,
    help="Workspace manager: git worktree + tmux session per branch.",
    rich_markup_mode="rich",
)
console = Console()
err = Console(stderr=True)


def _version_callback(value: bool) -> None:
    """Eager `--version` handler: print and exit before any command runs."""
    if value:
        console.print(f"wk {__version__}")
        raise typer.Exit()


@app.callback()
def _main(
    version: bool = typer.Option(
        False, "--version", "-V",
        callback=_version_callback, is_eager=True,
        help="Show the wk version and exit.",
    ),
) -> None:
    """Workspace manager: git worktree + tmux session per branch."""


@app.command()
def version() -> None:
    """Print the wk version (same as `wk --version`)."""
    console.print(f"wk {__version__}")


@app.command()
def doctor() -> None:
    """Check that wk's dependencies and tmux bindings are installed.

    A mise/binary-only install gets the `wk` CLI but not the tmux config, so
    the documented keystrokes (`prefix W`, `prefix M-g`, …) silently do
    nothing. This reports what's present, points at what's missing, and exits
    non-zero if a required tool is absent.
    """
    console.print(f"[bold]wk {__version__}[/bold]")
    missing_required = False

    def _tool(name: str, required: bool, note: str = "") -> None:
        nonlocal missing_required
        ok = shutil.which(name) is not None
        if ok:
            glyph, tag = "[green]✓[/green]", ""
        elif required:
            glyph, tag, missing_required = "[red]✗[/red]", " [red](required)[/red]", True
        else:
            glyph, tag = "[yellow]○[/yellow]", " [dim](optional)[/dim]"
        suffix = f" [dim]— {note}[/dim]" if (note and not ok) else ""
        console.print(f"  {glyph} {name}{tag}{suffix}")

    console.print("[dim]tools[/dim]")
    _tool("git", True)
    _tool("tmux", True)
    _tool("fzf", True)
    _tool("lazygit", False, "the `prefix M-g` git popup")
    _tool("fish", False)
    _tool("uv", True)

    console.print("[dim]tmux config[/dim]")
    loaded = ""
    if shutil.which("tmux"):
        loaded = run(
            ["tmux", "show-options", "-gv", "@wk-conf-loaded"], check=False
        ).stdout.strip()
    if loaded == "1":
        console.print("  [green]✓[/green] wk.conf bindings loaded (prefix W, M-g, …)")
    else:
        console.print("  [yellow]○[/yellow] wk.conf not loaded — keystrokes won't work")
        console.print(
            "    [dim]→ clone the repo and run ./install.sh, or source wk.conf "
            "from your tmux.conf[/dim]"
        )
        console.print(
            "    [dim]  (a mise/binary-only install ships the CLI, not the "
            "tmux bindings)[/dim]"
        )

    if missing_required:
        raise typer.Exit(1)


# ---------------------------------------------------------------------------
# config
# ---------------------------------------------------------------------------

# Where worktrees live. Default: a `.worktrees/` dir *inside* the main repo,
# i.e. `<repo>/.worktrees/<branch>`. Override with WK_WORKTREE_ROOT.
# Because this nests working copies inside the repo, we keep `.worktrees/`
# out of the parent's `git status` via `.git/info/exclude` (see
# `ensure_worktrees_ignored`).
WORKTREE_ROOT_ENV = "WK_WORKTREE_ROOT"

# Command to run in the main (chat) pane. Override with WK_AGENT_CMD.
# Tries `claude -c` first to resume the most recent conversation for this
# worktree; if there's no prior session, claude exits non-zero and the
# `|| claude` fallback starts a fresh one. Net effect: open keeps your
# thread, new workspaces still get a clean start.
AGENT_CMD_ENV = "WK_AGENT_CMD"
DEFAULT_AGENT_CMD = "claude -c || claude"

# Name of the cross-workspace dashboard session.
DASHBOARD_SESSION = "wk-dashboard"

# Default base branch for new worktrees.
DEFAULT_BASE = "origin/main"

# Where `wk pr <url>` looks for the local clone of a PR's repo when the
# PR lives in a repo other than the current one. Override with
# WK_PR_REPO_ROOT. A clone is matched by its `origin` remote slug.
PR_REPO_ROOT_ENV = "WK_PR_REPO_ROOT"
DEFAULT_PR_REPO_ROOT = "~/_Work"

# When `wk pr <issue-link>` searches GitHub org-wide for the PR that
# references an issue key, it scopes the search to this GitHub org.
# Defaults to the owner of the current repo's `origin` remote.
PR_SEARCH_OWNER_ENV = "WK_PR_SEARCH_OWNER"

# Marker directory placed in each wk-managed worktree. Its presence
# distinguishes wk workspaces from worktrees created directly with
# `git worktree add`, so the sidebar can show only what wk owns.
WK_MARKER_DIR = ".wk"


