@app.command()
def switch(
    branch: Optional[str] = typer.Argument(None, help="Branch; omit for fzf picker."),
) -> None:
    """Switch to an existing workspace's tmux session.

    With BRANCH, jumps straight to that workspace (accepts the branch, its
    session-form slug, or the full session name). With no argument, opens the
    fzf hub — this repo's workspaces (running + idle) first, then every running
    wk session in OTHER repos (a `repo` column disambiguates), so you can jump
    to any agent from anywhere, even outside a repo. Live preview (task, recent
    commits, git status) and single-key actions: enter=switch, ctrl-n=new,
    ctrl-d=rm, ctrl-x=cancel, ctrl-r=refresh. A finished `--auto` task shows ✓.
    Attaches when run outside tmux, switches the client when inside.

    Cross-repo discovery is derived live from tmux (each wk session is tagged
    with its branch + path) — no registry, no new state. Idle workspaces in
    OTHER repos aren't listed (nothing running to tag them); cd there to resume.
    enter/switch works on any row; ctrl-d/ctrl-x act on the current repo (on a
    cross-repo row they report no-match — switch in and act there).

    The hub does the *non-blocking* verbs in place; reading a task's live
    output or merging it are deliberately not bound here (they block or are
    interactive) — switch into the task and use `wk task-output`/`task-merge`,
    or the `--rm` flag. Auto-refresh is the passive sidebar's job; the hub
    refreshes on demand (ctrl-r) to stay free of a background timer.
    """
    require("tmux")
    # The hub is global: this repo's workspaces first, then every running wk
    # session in other repos — so `prefix W` works from anywhere, even outside
    # a repo, and lets you jump to any agent.
    workspaces = hub_workspaces()
    if not workspaces:
        # Nothing anywhere to switch to. Interactive + in a repo → offer to
        # create the first workspace (named so it's clear WHERE it lands).
        # Headless or outside a repo → a clear die (scripts still see failure).
        if branch is None and sys.stdin.isatty() and in_git_repo():
            repo = repo_root()
            console.print(
                f"No wk workspaces in [bold]{repo.name}[/bold] "
                f"[dim]({repo})[/dim] yet — let's make your first one."
            )
            name = typer.prompt(
                f"new branch in {repo.name} off {DEFAULT_BASE} (empty to cancel)",
                default="", show_default=False,
            ).strip()
            if not name:
                console.print("[dim](cancelled)[/dim]")
                raise typer.Exit(0)
            open_ref(name, DEFAULT_BASE, no_attach=False, no_fetch=False)
            return
        if not in_git_repo():
            die("no running wk sessions",
                hint="cd into a repo and `wk new <branch>` to start one")
        die("no workspaces to switch to", hint="`wk new <branch>` creates one")

    target: Optional[Workspace] = None
    if branch:
        for w in workspaces:
            if _matches_query(branch, w):
                target = w
                break
        if target is None:
            die(f"no workspace matching {branch!r}", hint="`wk list` shows every workspace")
    else:
        require("fzf")
        wk = _wk_bin()
        current = current_session()
        lines = [_picker_line(w, current) for w in workspaces]

        proc = subprocess.run(
            [
                "fzf",
                "--with-nth=2",
                "--delimiter=\t",
                "--no-info",
                "--no-scrollbar",
                "--prompt=workspace❯ ",
                "--header=enter=switch  ctrl-n=new  ctrl-d=rm  ctrl-x=cancel  ctrl-r=refresh  /=filter\n"
                "✓ task done   ● running   · idle   ✱ dirty",
                "--reverse",
                "--height=100%",
                "--cycle",
                # Preview shows task + recent commits + status. Visible by
                # default since the popup has room.
                f"--preview={wk} _preview {{1}}",
                "--preview-window=right:60%:wrap",
                "--bind=ctrl-p:toggle-preview",
                # Vim-style nav by default; `/` enters filter mode where
                # typing filters as usual. Esc keeps its fzf default (abort),
                # which is what dismisses the popup.
                "--disabled",
                "--bind=j:down,k:up,g:first,G:last",
                "--bind=/:unbind(j,k,g,G)+enable-search+clear-query",
                # ctrl-n / ctrl-d quick actions on the highlighted workspace.
                # ctrl-d does NOT pass --force: a fat-fingered ctrl-d in the
                # picker must not silently destroy a dirty worktree + unmerged
                # branch. `wk rm` refuses on a dirty tree, and only force-deletes
                # the branch ref under --force — so a clean-but-unmerged branch
                # is preserved here too.
                f"--bind=ctrl-n:execute(tmux command-prompt -p 'new branch:' 'run-shell \"{wk} new %%\"')+abort",
                f"--bind=ctrl-d:execute({wk} rm {{1}})+reload({wk} _list-once)",
                # ctrl-x cancels a task (kills its session, keeps the worktree +
                # output — non-destructive, recoverable via task-retry). ctrl-r
                # refreshes the list on demand (no background timer; the sidebar
                # is the always-on auto-refreshing view).
                f"--bind=ctrl-x:execute({wk} task-cancel {{1}})+reload({wk} _list-once)",
                f"--bind=ctrl-r:reload({wk} _list-once)",
            ],
            input="\n".join(lines),
            text=True,
            capture_output=True,
            env={**os.environ, "WK_CURRENT": current},
        )
        if proc.returncode != 0 or not proc.stdout.strip():
            raise typer.Exit(0)
        picked_session = proc.stdout.strip().split("\t", 1)[0]
        target = next(w for w in workspaces if w.session == picked_session)

    # Ensure the session actually exists; rebuild if not
    if not target.has_session:
        console.print(f"[dim]session missing; rebuilding…[/dim]")
        build_session(target.session, target.path, agent_cmd(), branch=target.branch)

    attach_or_switch(target.session)


def _set_last_wk_session(session: str) -> None:
    """Remember SESSION as the most recently visited wk session, so
    `wk cycle last` can toggle back to it. Stored as a server-wide tmux
    user option so it survives detach/re-attach but resets when tmux
    server exits."""
    run(
        ["tmux", "set-option", "-s", "@wk-last-session", session],
        check=False,
    )


def _get_last_wk_session() -> Optional[str]:
    r = run(
        ["tmux", "show-options", "-s", "-v", "@wk-last-session"],
        check=False,
    )
    val = r.stdout.strip() if r.returncode == 0 else ""
    return val or None


@app.command("cycle")
def cycle(
    direction: str = typer.Argument(
        "next",
        help="'next' / 'prev' / 'last' (or 'n' / 'p' / 'l').",
    ),
) -> None:
    """Switch among *running* wk sessions.

    Three modes:

    \b
      next / n  →  alphabetically next wk session (wraps)
      prev / p  →  alphabetically previous wk session (wraps)
      last / l  →  toggle back to the most recently visited wk session
                   (alt-tab style)

    Only sessions tagged `@wk` are considered — plain tmux sessions and
    `wk-dashboard` don't pollute the cycle. Every cycle records the
    session it's leaving so `last` always has a target.

    Suggested non-prefix tmux bindings (add to your config):

    \b
        bind-key -n M-]  run-shell "wk cycle next"
        bind-key -n M-[  run-shell "wk cycle prev"
        bind-key -n M-m  run-shell "wk cycle last"
    """
    require("tmux")
    if direction in ("n", "next"):
        delta: Optional[int] = 1
    elif direction in ("p", "prev"):
        delta = -1
    elif direction in ("l", "last"):
        delta = None  # special: toggle to last visited
    else:
        die(f"direction must be next / prev / last; got {direction!r}")
    if not in_tmux():
        die("not inside tmux; cycle needs a current session to step from")

    sessions = sorted(wk_tmux_sessions())
    if not sessions:
        return
    r = run(["tmux", "display-message", "-p", "#S"], check=False)
    current = r.stdout.strip()

    if delta is None:
        # last: toggle to the previously-recorded wk session.
        last = _get_last_wk_session()
        if not last or last == current or last not in sessions:
            return
        target = last
    else:
        try:
            idx = sessions.index(current)
        except ValueError:
            idx = -1 if delta > 0 else 0
        target = sessions[(idx + delta) % len(sessions)]
        if target == current:
            return  # only one wk session running

    # Record where we were *before* switching, so the next `cycle last`
    # toggles back here. Done for next/prev/last alike, which makes
    # last-toggling between two workspaces feel like alt-tab.
    _set_last_wk_session(current)
    run(["tmux", "switch-client", "-t", target], check=False)


# --- teardown: close (keep worktree) / rm (destroy) ---
@app.command()
def close(
    branch: Optional[str] = typer.Argument(
        None, help="Workspace to close. Default: current tmux session."
    ),
) -> None:
    """Kill the tmux session but keep the worktree on disk.

    Use this when you're done with a workspace for now but might come
    back to it. The branch, worktree, and any uncommitted changes survive
    — `wk open <branch>` rebuilds the session later. For total destruction
    (kill session + remove worktree + delete branch), use `wk rm`.

    Refuses to kill non-wk tmux sessions (those without the @wk option).
    """
    require("tmux")

    if branch:
        target = require_workspace(branch)
        session = target.session
        label = target.branch
    else:
        if not in_tmux():
            die("not inside tmux; pass a branch / workspace name")
        r = run(["tmux", "display-message", "-p", "#S"], check=False)
        session = r.stdout.strip()
        # Find the branch for nicer output, falling back to the session name.
        match = next(
            (w for w in all_workspaces() if w.session == session),
            None,
        )
        label = match.branch if match else session

    # Refuse to kill sessions wk doesn't own — protects plain tmux sessions
    # that happen to share a name with a branch.
    r = run(
        ["tmux", "show-options", "-v", "-t", session, "@wk"],
        check=False,
    )
    if r.returncode != 0 or r.stdout.strip() != "1":
        die(f"session {session!r} isn't a wk session; refusing to kill")

    run(["tmux", "kill-session", "-t", session], check=False)
    console.print(
        f"[green]✓[/green] closed [bold]{label}[/bold] "
        f"[dim](worktree preserved; `wk open {label}` to resume)[/dim]"
    )


def _do_rm(w: Workspace, main: Path, force: bool, keep_branch: bool) -> None:
    """The actual destructive work for `wk rm`: kill session, remove worktree,
    optionally delete the branch. Best-effort — git failures don't bubble up
    because we've already passed pre-flight checks and partial cleanup is
    better than a half-done abort."""
    if w.has_session:
        run(["tmux", "kill-session", "-t", w.session], check=False)
    args = ["git", "-C", str(main), "worktree", "remove", str(w.path)]
    if force:
        args.append("--force")
    wt_result = run(args, check=False)
    if wt_result.returncode != 0:
        # Don't claim success we didn't achieve — and don't go on to delete the
        # branch ref for a worktree that's still on disk.
        console.print(
            f"[red]✗[/red] could not remove worktree {w.path}: "
            f"{wt_result.stderr.strip() or 'git worktree remove failed'}"
        )
        return
    if not keep_branch:
        # `-d` refuses to delete an unmerged branch; only escalate to the
        # force-delete `-D` when the caller passed --force. A clean worktree can
        # still hold committed-but-unmerged work, so default-rm must not discard
        # the branch ref silently.
        flag = "-D" if force else "-d"
        br = run(["git", "-C", str(main), "branch", flag, w.branch], check=False)
        if br.returncode != 0 and not force:
            console.print(
                f"[yellow]warning:[/yellow] kept branch [bold]{w.branch}[/bold] "
                f"(has unmerged work; `git branch -D {w.branch}` or "
                f"`wk rm --force` to delete)"
            )


@app.command()
def rm(
    branch: Optional[str] = typer.Argument(
        None, help="Branch / workspace to remove. Default: current tmux session."
    ),
    force: bool = typer.Option(False, "--force", "-f", help="Remove even if dirty."),
    keep_branch: bool = typer.Option(
        False, "--keep-branch", help="Keep the branch ref after removing the worktree."
    ),
) -> None:
    """Kill the tmux session and remove the worktree.

    With no BRANCH, removes the workspace whose tmux session you're
    currently in. Killing the session you're attached to needs special
    handling — the rm work is detached into a background process so it
    survives the session dying. tmux auto-switches your client to another
    session (or detaches) when the kill lands.
    """
    require("git")
    require("tmux")
    main = repo_root()
    workspaces = {w.branch: w for w in all_workspaces()}

    if branch is None:
        if not in_tmux():
            die("not inside tmux; pass a branch name")
        r = run(["tmux", "display-message", "-p", "#S"], check=False)
        current_session = r.stdout.strip()
        match = next(
            (w for w in workspaces.values() if w.session == current_session),
            None,
        )
        if match is None:
            die(f"current session {current_session!r} isn't a wk workspace")
        branch = match.branch

    w = workspaces.get(branch)
    if w is None:
        die(f"no workspace for {branch!r}", hint="`wk list` shows every workspace")
    if w.dirty and not force:
        die("worktree is dirty; use --force or commit first")

    # Self-destruct? If our tmux session is the one we're killing, our
    # Python process is doomed too. Re-spawn the rm in a detached child
    # so it survives the session kill.
    self_remove = False
    if in_tmux() and w.has_session:
        r = run(["tmux", "display-message", "-p", "#S"], check=False)
        if r.stdout.strip() == w.session:
            self_remove = True

    if self_remove:
        wk_bin = _wk_bin()
        args = [wk_bin, "_rm-detached", w.branch]
        if force:
            args.append("--force")
        if keep_branch:
            args.append("--keep-branch")
        subprocess.Popen(
            args,
            start_new_session=True,  # become a new session leader → survives parent SIGHUP
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        # No success message — the popup/pane is about to die.
        return

    _do_rm(w, main, force, keep_branch)
    console.print(f"[green]✓[/green] removed {branch}")


@app.command("_rm-detached", hidden=True)
def _rm_detached(
    branch: str = typer.Argument(...),
    force: bool = typer.Option(False, "--force", "-f"),
    keep_branch: bool = typer.Option(False, "--keep-branch"),
) -> None:
    """Internal: finish the destructive work for `wk rm` from a process
    detached from the doomed tmux session. Spawned by `wk rm` when the
    current session is the one being removed."""
    require("git")
    require("tmux")
    main = repo_root()
    try:
        workspaces = {w.branch: w for w in all_workspaces()}
        w = workspaces.get(branch)
        if w is None:
            return
        _do_rm(w, main, force, keep_branch)
    except Exception:
        # We're detached with no terminal; surface the failure to a log so a
        # half-removed worktree isn't a silent mystery. (main/.git outlives
        # the worktree we're removing.)
        _log_detached_failure(main / ".git", f"_rm-detached {branch}")
        raise


