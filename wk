#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "typer>=0.12",
#     "rich>=13",
# ]
# ///
"""
wk — a tmux-based workspace manager modeled on Conductor / Superset.

Each workspace is:
  - a git worktree on its own branch
  - a tmux session of the same name
  - a 5-pane layout: (sidebar over shell) | Claude Code | (lazygit over terminal)
"""

from __future__ import annotations

import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Optional

import typer
from rich.console import Console
from rich.table import Table

app = typer.Typer(
    add_completion=False,
    no_args_is_help=True,
    help="Workspace manager: git worktree + tmux session per branch.",
    rich_markup_mode="rich",
)
console = Console()
err = Console(stderr=True)


# ---------------------------------------------------------------------------
# config
# ---------------------------------------------------------------------------

# Where worktrees live. Default: sibling dir next to the main repo,
# named `<repo>.worktrees/<branch>`. Override with WK_WORKTREE_ROOT.
WORKTREE_ROOT_ENV = "WK_WORKTREE_ROOT"

# Command to run in the main (chat) pane. Override with WK_AGENT_CMD.
# Tries `claude -c` first to resume the most recent conversation for this
# worktree; if there's no prior session, claude exits non-zero and the
# `|| claude` fallback starts a fresh one. Net effect: open keeps your
# thread, new workspaces still get a clean start.
AGENT_CMD_ENV = "WK_AGENT_CMD"
DEFAULT_AGENT_CMD = "claude -c || claude"

# Name of the cross-workspace dashboard session.
DASHBOARD_SESSION = "wk-dashboard"

# Default base branch for new worktrees.
DEFAULT_BASE = "origin/main"

# Marker directory placed in each wk-managed worktree. Its presence
# distinguishes wk workspaces from worktrees created directly with
# `git worktree add`, so the sidebar can show only what wk owns.
WK_MARKER_DIR = ".wk"


# ---------------------------------------------------------------------------
# helpers
# ---------------------------------------------------------------------------


def run(
    cmd: list[str],
    *,
    check: bool = True,
    capture: bool = True,
    cwd: Optional[Path] = None,
) -> subprocess.CompletedProcess[str]:
    """Run a command, returning the completed process."""
    return subprocess.run(
        cmd,
        check=check,
        capture_output=capture,
        text=True,
        cwd=cwd,
    )


def die(msg: str, code: int = 1) -> None:
    err.print(f"[red]error:[/red] {msg}")
    raise typer.Exit(code)


def require(tool: str) -> None:
    if shutil.which(tool) is None:
        die(f"{tool!r} not found on PATH")


def repo_root() -> Path:
    """Toplevel of the *main* repo (not the worktree we may be in)."""
    try:
        r = run(["git", "rev-parse", "--path-format=absolute", "--git-common-dir"])
    except subprocess.CalledProcessError:
        die("not inside a git repository")
    common_dir = Path(r.stdout.strip())
    # common_dir is .../<repo>/.git — parent is the main checkout
    return common_dir.parent


def repo_name() -> str:
    return repo_root().name


def worktree_root() -> Path:
    """Where all worktrees for this repo live."""
    override = os.environ.get(WORKTREE_ROOT_ENV)
    if override:
        return Path(override).expanduser()
    main = repo_root()
    return main.parent / f"{main.name}.worktrees"


def worktree_path(branch: str) -> Path:
    # branches like `feat/foo` become `feat-foo` on disk to avoid nested dirs
    safe = branch.replace("/", "-")
    return worktree_root() / safe


def session_name(branch: str) -> str:
    # tmux session names can't contain `.` or `:`. Normalize.
    return branch.replace("/", "-").replace(".", "-").replace(":", "-")


def agent_cmd() -> str:
    return os.environ.get(AGENT_CMD_ENV, DEFAULT_AGENT_CMD)


@dataclass
class Workspace:
    branch: str
    path: Path
    session: str
    has_session: bool
    dirty: bool
    ahead: int
    behind: int


def list_worktrees() -> list[tuple[str, Path]]:
    """Parse `git worktree list --porcelain`. Returns (branch, path) pairs.

    Skips the main checkout and detached HEADs. Includes every worktree
    git knows about — use `list_wk_worktrees()` to filter to wk-owned ones.
    """
    out = run(["git", "worktree", "list", "--porcelain"]).stdout
    main = repo_root()
    results: list[tuple[str, Path]] = []
    cur_path: Optional[Path] = None
    cur_branch: Optional[str] = None
    for line in out.splitlines() + [""]:  # trailing blank flushes last record
        if line.startswith("worktree "):
            cur_path = Path(line[len("worktree ") :])
            cur_branch = None
        elif line.startswith("branch "):
            ref = line[len("branch ") :]
            cur_branch = ref.removeprefix("refs/heads/")
        elif line == "":
            if cur_path and cur_branch and cur_path != main:
                results.append((cur_branch, cur_path))
            cur_path = None
            cur_branch = None
    return results


def is_wk_workspace(
    branch: str,
    path: Path,
    wk_sessions: Optional[set[str]] = None,
) -> bool:
    """Worktree is a wk workspace if it has a .wk/ marker OR a wk-tagged
    tmux session is currently running for it.

    "wk-tagged" means the session has the `@wk` user option set, which
    `build_session` does. A plain tmux session that happens to share the
    branch name does NOT make the worktree a wk workspace.

    The session check covers worktrees created with `wk open` before the
    marker existed — they show up in the sidebar as long as the session is
    alive, and get marked permanently next time `build_session` runs.
    """
    if (path / WK_MARKER_DIR).is_dir():
        return True
    if wk_sessions is None:
        return False
    return session_name(branch) in wk_sessions


def list_wk_worktrees() -> list[tuple[str, Path]]:
    """Like `list_worktrees`, but only worktrees wk owns (marker or wk session)."""
    wk_sessions = wk_tmux_sessions()
    return [
        (b, p) for b, p in list_worktrees()
        if is_wk_workspace(b, p, wk_sessions)
    ]


def mark_wk_workspace(path: Path) -> None:
    """Create the .wk/ marker (idempotent). Also writes a .gitignore inside
    so the marker dir doesn't end up tracked in the worktree's git history,
    and an AGENTS.md so coding agents (Claude, etc.) can self-orient."""
    marker = path / WK_MARKER_DIR
    marker.mkdir(exist_ok=True)
    gi = marker / ".gitignore"
    if not gi.exists():
        gi.write_text("*\n!.gitignore\n", encoding="utf-8")
    agents = marker / "AGENTS.md"
    if not agents.exists():
        agents.write_text(_AGENTS_MD, encoding="utf-8")


_AGENTS_MD = """\
# wk workspace context

This worktree is managed by `wk` (a tmux + git-worktree workspace manager).
When you read this file you can assume you're running inside the agent pane
of a wk tmux session.

## Runtime signals

These environment variables are set on every pane of the session:

- `WK_IN_WORKSPACE=1` — fast check that wk is active
- `WK_SESSION` — the tmux session name (slug form, no slashes)
- `WK_BRANCH` — the canonical git branch (may contain slashes)
- `WK_PATH` — the worktree root (typically equal to your starting cwd)

## Layout

The wk session has 5 panes:

  ┌──────────┬──────────────────────────┬──────────────────┐
  │ sidebar  │                          │   lazygit        │
  │ pane.1   │   agent (you)            │   pane.4         │
  ├──────────┤   pane.2 (visual idx 3)  ├──────────────────┤
  │ shell    │                          │   terminal       │
  │ pane.4   │                          │   pane.5         │
  └──────────┴──────────────────────────┴──────────────────┘

## Useful wk commands

- `wk lg-cd [path]` — retarget the lazygit pane at a directory. Run this
  when you start working in a different repo, submodule, or subrepo than
  where wk started, so the user's git UI follows along. Defaults to the
  active pane's cwd if no path is given.
- `wk task <prompt>` — spawn another wk workspace on a new branch for an
  independent task. Useful when the user asks for parallel work.
- `wk list` — show all wk workspaces with branch/status.
- `wk cd [branch]` — print the worktree path for `cd` integration.

## Conventions

- The `.wk/` directory in this worktree is wk-managed and gitignored. You
  can write notes here (e.g. `.wk/notes.md`) that won't pollute the repo.
- The `.wk/task.md` file, if present, is the original task prompt that
  `wk task` was invoked with — useful as ground-truth context.
"""


def tmux_sessions() -> set[str]:
    r = run(["tmux", "ls", "-F", "#{session_name}"], check=False)
    if r.returncode != 0:
        return set()
    return {line.strip() for line in r.stdout.splitlines() if line.strip()}


def wk_tmux_sessions() -> set[str]:
    """Only sessions that wk created (have the `@wk` user option set).

    Distinguishes a wk-managed session from a plain tmux session that
    happens to share a name with a git branch.
    """
    r = run(
        ["tmux", "ls", "-F", "#{session_name}\t#{@wk}"],
        check=False,
    )
    if r.returncode != 0:
        return set()
    out: set[str] = set()
    for line in r.stdout.splitlines():
        if "\t" not in line:
            continue
        name, marker = line.split("\t", 1)
        if marker.strip() == "1":
            out.add(name.strip())
    return out


def workspace_status(branch: str, path: Path, sessions: set[str]) -> Workspace:
    name = session_name(branch)
    # dirty?
    dirty = bool(
        run(["git", "-C", str(path), "status", "--porcelain"]).stdout.strip()
    )
    # ahead/behind vs base
    ahead = behind = 0
    base = os.environ.get("WK_BASE", DEFAULT_BASE)
    rev = run(
        ["git", "-C", str(path), "rev-list", "--left-right", "--count", f"{base}...HEAD"],
        check=False,
    )
    if rev.returncode == 0 and rev.stdout.strip():
        parts = rev.stdout.split()
        if len(parts) == 2:
            behind, ahead = int(parts[0]), int(parts[1])
    return Workspace(
        branch=branch,
        path=path,
        session=name,
        has_session=name in sessions,
        dirty=dirty,
        ahead=ahead,
        behind=behind,
    )


def all_workspaces() -> list[Workspace]:
    # Use wk-only sessions so `has_session` reflects "wk session is running",
    # not "any tmux session with this name exists".
    sessions = wk_tmux_sessions()
    return [workspace_status(b, p, sessions) for b, p in list_wk_worktrees()]


def in_tmux() -> bool:
    return "TMUX" in os.environ


def attach_or_switch(session: str) -> None:
    """Attach if outside tmux, switch-client if inside."""
    if in_tmux():
        os.execvp("tmux", ["tmux", "switch-client", "-t", session])
    else:
        os.execvp("tmux", ["tmux", "attach", "-t", session])


# ---------------------------------------------------------------------------
# tmux session construction
# ---------------------------------------------------------------------------


def _wk_bin() -> str:
    """Path to this script for sub-invocations from tmux panes."""
    return shutil.which("wk") or os.path.abspath(sys.argv[0])


def _shell_wrap(cmd: str) -> list[str]:
    """Wrap a synthetic command for tmux. Always sh — these strings are sh
    syntax (loops, inline env vars, `&&`/`||` between subshells), which fish
    won't parse. Interactive panes inherit the user's default shell elsewhere."""
    return ["sh", "-c", cmd]


# Target widths (cols) and height percentages for the 5-pane layout.
# Tuned for ~290-col widescreen tmux windows (UWQHD 3440px); tmux scales
# proportionally when attached to a smaller terminal.
LEFT_COL_COLS = 42      # sidebar + shell column
RIGHT_COL_COLS = 75     # lazygit + terminal column
SIDEBAR_PCT = 20        # sidebar gets this percent of left col height
LAZYGIT_PCT = 60        # lazygit gets this percent of right col height


# sh command that launches lazygit with wk's narrow-pane config if it exists,
# otherwise plain lazygit. If lazygit isn't installed, falls back to a shell.
LAZYGIT_CMD = (
    'WK_LG_CFG="${XDG_CONFIG_HOME:-$HOME/.config}/wk/lazygit.yml"; '
    "if command -v lazygit >/dev/null; then "
    '  if [ -f "$WK_LG_CFG" ]; then exec lazygit -ucf "$WK_LG_CFG"; '
    "  else exec lazygit; fi; "
    "else "
    '  echo "lazygit not installed — install it or use the terminal pane"; '
    "  exec ${SHELL:-sh}; "
    "fi"
)


def build_session(
    session: str,
    wt: Path,
    agent: str,
    branch: Optional[str] = None,
) -> None:
    """Create a detached session with the 5-pane layout.

    Panes are 1-indexed (matches user's `pane-base-index 1` tmux setting):

        ┌──────────┬──────────────────────────┬──────────────────┐
        │ sidebar  │                          │   lazygit        │
        │ pane.1   │                          │   pane.3         │
        ├──────────┤   agent (Claude Code)    ├──────────────────┤
        │          │   pane.2                 │                  │
        │ shell    │                          │   terminal       │
        │ pane.4   │                          │   pane.5         │
        └──────────┴──────────────────────────┴──────────────────┘
    """
    wk = _wk_bin()
    total_cols = 290
    real_branch = branch or session

    # Mark this worktree as a wk workspace before we touch tmux — the sidebar
    # filters on this, and `wk task` may also write its own files under .wk/.
    mark_wk_workspace(wt)

    # Environment exposed to every pane in the session. Lets agents (claude,
    # etc.) detect they're inside wk and find the workspace context. tmux's
    # -e flag on new-session applies to all panes split off this session.
    env_flags: list[str] = []
    for k, v in [
        ("WK_IN_WORKSPACE", "1"),
        ("WK_SESSION", session),
        ("WK_BRANCH", real_branch),
        ("WK_PATH", str(wt)),
    ]:
        env_flags.extend(["-e", f"{k}={v}"])

    # Sidebar (initial pane). Starts with `wk sidebar` running.
    # `-P -F #{pane_id}` prints the new pane's stable `%NN` id; we use that
    # for subsequent splits instead of numeric indices, which tmux renumbers
    # via tree-traversal order whenever the layout changes.
    sidebar_id = run(
        [
            "tmux", "new-session", "-d",
            "-s", session,
            "-c", str(wt),
            "-x", str(total_cols), "-y", "75",  # reshaped on attach
            "-n", "work",
            *env_flags,
            "-P", "-F", "#{pane_id}",
            *_shell_wrap(f"WK_CURRENT={session} {wk} sidebar"),
        ]
    ).stdout.strip()

    # Tag the session as wk-managed so tmux-resurrect filters and other tools
    # can identify it. Stored as tmux user options, readable via
    # `tmux show-options -v -t <session> @wk`.
    run(["tmux", "set-option", "-t", session, "@wk", "1"])
    run(["tmux", "set-option", "-t", session, "@wk-branch", real_branch])
    run(["tmux", "set-option", "-t", session, "@wk-path", str(wt)])

    # Agent. Split right of sidebar; new pane takes everything except the
    # left column.
    agent_width = total_cols - LEFT_COL_COLS
    agent_id = run(
        [
            "tmux", "split-window", "-h",
            "-t", sidebar_id,
            "-c", str(wt),
            "-l", str(agent_width),
            "-P", "-F", "#{pane_id}",
            agent,
        ]
    ).stdout.strip()

    # Lazygit — right column, top. Split right of agent.
    lazygit_id = run(
        [
            "tmux", "split-window", "-h",
            "-t", agent_id,
            "-c", str(wt),
            "-l", str(RIGHT_COL_COLS),
            "-P", "-F", "#{pane_id}",
            *_shell_wrap(LAZYGIT_CMD),
        ]
    ).stdout.strip()

    # Remember the lazygit pane id so `wk lg-cd` can retarget it later,
    # even after the layout has been resized or rearranged.
    run(["tmux", "set-option", "-t", session, "@wk-lazygit-pane", lazygit_id])

    # Shell — left column, bottom. Split below sidebar.
    run(
        [
            "tmux", "split-window", "-v",
            "-t", sidebar_id,
            "-c", str(wt),
            "-l", f"{100 - SIDEBAR_PCT}%",
        ]
    )

    # Terminal — right column, bottom. Split below lazygit.
    run(
        [
            "tmux", "split-window", "-v",
            "-t", lazygit_id,
            "-c", str(wt),
            "-l", f"{100 - LAZYGIT_PCT}%",
        ]
    )

    # Land in the agent pane on attach.
    run(["tmux", "select-pane", "-t", agent_id])


import json
import re
import time as _time


# ---------------------------------------------------------------------------
# branch-name + task helpers
# ---------------------------------------------------------------------------


# A valid branch name for our purposes: lowercase, hyphen-separated,
# starts with a letter, 3–60 chars. Loose enough to accept what Claude
# typically produces, strict enough to keep filesystem paths sane.
_BRANCH_RE = re.compile(r"^[a-z][a-z0-9-]{2,59}$")


def slugify(text: str, max_words: int = 5) -> str:
    """Deterministic fallback: take first words, lowercase, dash-separate.

    Used when the AI branch picker fails or is skipped. Always returns
    a string that matches _BRANCH_RE (min 3 chars, leading letter).
    """
    # Replace non-alphanumeric runs with spaces, then take the first N words.
    cleaned = re.sub(r"[^a-zA-Z0-9]+", " ", text).strip().lower()
    words = cleaned.split()[:max_words]
    slug = "-".join(words) if words else ""
    # Collapse repeated dashes, trim to 60.
    slug = re.sub(r"-+", "-", slug).strip("-")[:60]
    # Ensure leading letter and minimum length (3 chars per _BRANCH_RE).
    if not slug or not slug[0].isalpha():
        slug = f"task-{slug}".strip("-") if slug else f"task-{int(_time.time())}"
    if len(slug) < 3:
        slug = f"task-{slug}"
    return slug


_BRANCH_PROMPT = """\
You are naming a git branch for the following task. Reply with ONLY the
branch name — no quotes, no explanation, no markdown. Rules:

- lowercase
- 2 to 6 words joined by hyphens
- start with a letter
- describe the task (not the verb): "fix-flaky-session-test", not "fix"
- no slashes, no spaces, no underscores

Task:
{prompt}

Branch name:"""


def pick_branch_name(prompt: str, timeout_seconds: int = 30) -> tuple[str, str]:
    """Ask `claude -p` to suggest a branch name. Returns (name, source).

    `source` is "claude" on success, "slug" on fallback. Never raises;
    falls back to slugify() on timeout, network, parse, or validation errors.
    """
    if shutil.which("claude") is None:
        return slugify(prompt), "slug"
    try:
        proc = subprocess.run(
            ["claude", "-p", "--output-format", "json", _BRANCH_PROMPT.format(prompt=prompt)],
            capture_output=True,
            text=True,
            timeout=timeout_seconds,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return slugify(prompt), "slug"

    if proc.returncode != 0 or not proc.stdout.strip():
        return slugify(prompt), "slug"

    try:
        payload = json.loads(proc.stdout)
        raw = str(payload.get("result", "")).strip()
    except (json.JSONDecodeError, AttributeError):
        return slugify(prompt), "slug"

    # Claude sometimes wraps the name in backticks, quotes, or extra prose.
    # Take the last non-empty line, strip surrounding punctuation.
    last_line = raw.splitlines()[-1].strip() if raw.splitlines() else ""
    candidate = last_line.strip("`\"' \t.,").lower().replace(" ", "-").replace("_", "-")
    candidate = re.sub(r"-+", "-", candidate).strip("-")

    if _BRANCH_RE.match(candidate):
        return candidate, "claude"
    return slugify(prompt), "slug"


@dataclass
class WorkspaceState:
    """Result of resolving what to do for a `wk open` request.

    `branch` is the canonical git branch name (may contain slashes).
    `wt` is the worktree path that should be used (may be wk's preferred path,
    or an external path picked up from `git worktree list`).
    `created` is True if we created the worktree in this call.
    `branch_created` is True if we created the branch ref in this call.
    """
    branch: str
    wt: Path
    session: str
    created: bool
    branch_created: bool


def find_existing_worktree(branch: str) -> Optional[tuple[str, Path]]:
    """Look up an existing worktree for BRANCH, if any.

    Matches against the real branch name AND the session-form alias
    (`feat/admin-phase-1` matches input `feat-admin-phase-1`), since users
    often type the session-style name when invoking `wk open`.

    Returns (real_branch_name, path) on hit, or None.
    """
    out = run(["git", "worktree", "list", "--porcelain"]).stdout
    cur_path: Optional[Path] = None
    for line in out.splitlines() + [""]:
        if line.startswith("worktree "):
            cur_path = Path(line[len("worktree ") :])
        elif line.startswith("branch "):
            ref = line[len("branch ") :].removeprefix("refs/heads/")
            if cur_path is not None and (ref == branch or session_name(ref) == branch):
                return ref, cur_path
        elif line == "":
            cur_path = None
    return None


def resolve_branch_alias(branch: str) -> str:
    """If BRANCH is a session-form alias (hyphens) of a real branch (slashes),
    return the real branch name. Otherwise return BRANCH unchanged.

    Looks across all local branches, not just ones with worktrees — so this
    works for branches the user hasn't checked out yet.
    """
    main = repo_root()
    r = run(
        ["git", "-C", str(main), "for-each-ref", "--format=%(refname:short)", "refs/heads/"],
        check=False,
    )
    if r.returncode != 0:
        return branch
    for ref in r.stdout.splitlines():
        ref = ref.strip()
        if ref == branch:
            return ref  # exact match wins
        if session_name(ref) == branch:
            return ref  # session-form alias
    return branch


def branch_exists_locally(branch: str) -> bool:
    main = repo_root()
    r = run(
        ["git", "-C", str(main), "rev-parse", "--verify", f"refs/heads/{branch}"],
        check=False,
    )
    return r.returncode == 0


def branch_exists_on_remote(branch: str, remote: str = "origin") -> bool:
    """Does the branch exist on `remote` (after most-recent fetch)?"""
    main = repo_root()
    r = run(
        [
            "git", "-C", str(main),
            "rev-parse", "--verify", f"refs/remotes/{remote}/{branch}",
        ],
        check=False,
    )
    return r.returncode == 0


def resolve_workspace(
    branch: str,
    base: str,
    fetch: bool = True,
    strict_new: bool = False,
) -> WorkspaceState:
    """Resolve everything needed to open a workspace for BRANCH.

    Walks the six-case state space:

    1/2.  Branch + worktree exist (anywhere)         → use that worktree
    3.    Branch exists, no worktree                 → add worktree at wk's path
    4.    Branch missing locally, exists on remote   → fetch, create from remote
    5.    Branch missing entirely                    → create from BASE
    6.    (Same as 1/2 — external worktrees included)

    When `strict_new=True`, errors if the branch already exists. Used by
    `wk new` so it preserves its "I want a fresh thing" semantics.

    Does not build the tmux session — that's the caller's job. Returns
    a WorkspaceState describing what's now true on disk.
    """
    main = repo_root()

    # Normalize the input: if the user typed a session-form alias (hyphens),
    # find the real branch name (with slashes) so all downstream git ops use
    # the canonical ref. Prevents creating duplicate hyphen-named branches.
    branch = resolve_branch_alias(branch)
    session = session_name(branch)

    # 1/2/6. Existing worktree (wk-created or external).
    existing = find_existing_worktree(branch)
    if existing is not None:
        real_branch, existing_wt = existing
        if strict_new:
            die(f"branch {real_branch!r} already has a worktree at {existing_wt}")
        return WorkspaceState(
            branch=real_branch,
            wt=existing_wt, session=session_name(real_branch),
            created=False, branch_created=False,
        )

    # No worktree exists. Decide where to put one and how to create the branch.
    if fetch:
        console.print("[dim]fetching…[/dim]")
        run(
            ["git", "-C", str(main), "fetch", "--prune"],
            check=False, capture=True,
        )

    wt = worktree_path(branch)
    # Defensive: refuse to create on top of a non-empty directory that git
    # doesn't know about. That's almost always leftover crud worth surfacing.
    if wt.exists():
        die(
            f"path exists but isn't a registered git worktree: {wt}\n"
            f"  remove or rename it, then re-run"
        )

    wt.parent.mkdir(parents=True, exist_ok=True)

    if branch_exists_locally(branch):
        if strict_new:
            die(
                f"branch {branch!r} already exists locally; "
                f"use `wk open {branch}` to use it"
            )
        # Case 3.
        console.print(f"[dim]branch exists; checking out into worktree[/dim]")
        run(["git", "-C", str(main), "worktree", "add", str(wt), branch])
        return WorkspaceState(branch=branch, wt=wt, session=session, created=True, branch_created=False)

    if branch_exists_on_remote(branch):
        # Case 4. `git worktree add` with a local branch name that matches
        # a remote-tracking ref will set up tracking automatically.
        console.print(f"[dim]branch on remote; creating tracking branch[/dim]")
        run(
            ["git", "-C", str(main), "worktree", "add",
             "--track", "-b", branch, str(wt), f"origin/{branch}"],
        )
        return WorkspaceState(branch=branch, wt=wt, session=session, created=True, branch_created=True)

    # Case 5.
    console.print(f"[dim]creating branch {branch} from {base}[/dim]")
    run(
        ["git", "-C", str(main), "worktree", "add", "-b", branch, str(wt), base]
    )
    return WorkspaceState(branch=branch, wt=wt, session=session, created=True, branch_created=True)


