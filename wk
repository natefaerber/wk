# commands
# ---------------------------------------------------------------------------


@app.command()
def new(
    branch: str = typer.Argument(..., help="Branch name for the new workspace."),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b", help="Base ref to branch from."
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
) -> None:
    """Create a [bold]new[/bold] worktree + tmux session for BRANCH and attach.

    Errors if the branch already exists. For a forgiving "open whatever's
    there, or make it if not" command, use `wk open` instead.
    """
    require("git")
    require("tmux")

    session = session_name(branch)
    if session in tmux_sessions():
        die(f"tmux session already exists: {session}")

    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=True)

    build_session(state.session, state.wt, agent_cmd())
    console.print(f"[green]✓[/green] workspace [bold]{branch}[/bold] ready at {state.wt}")

    if not no_attach:
        attach_or_switch(state.session)


@app.command("open")
def open_cmd(
    branch: str = typer.Argument(..., help="Branch name to open."),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b",
        help="Base ref (used only if creating a new branch).",
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
) -> None:
    """Open BRANCH — attach if running, rebuild if not, create if missing.

    Forgiving counterpart to `wk new`. Handles every case:

    \b
      branch + worktree + session all exist  →  attach
      branch + worktree exist, no session    →  rebuild session, attach
      branch exists, no worktree             →  add worktree, build, attach
      branch on remote, not local            →  fetch, track, build, attach
      branch nowhere                         →  create from --base, build, attach

    Worktrees created outside `wk` (e.g. `git worktree add ...` directly)
    are recognized; their existing path is used, not wk's preferred path.
    """
    require("git")
    require("tmux")

    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=False)

    if state.session in tmux_sessions():
        console.print(f"[dim]session running; attaching[/dim]")
    else:
        build_session(state.session, state.wt, agent_cmd())
        # Set tags. (resolve_workspace doesn't touch tmux, so we do it here
        # after build_session has created the session.)
        if state.created:
            console.print(f"[green]✓[/green] workspace [bold]{branch}[/bold] ready at {state.wt}")
        else:
            console.print(f"[green]✓[/green] rebuilt session for [bold]{branch}[/bold]")

    if not no_attach:
        attach_or_switch(state.session)


@app.command()
def task(
    prompt: str = typer.Argument(..., help="The task description / prompt for Claude."),
    branch: Optional[str] = typer.Option(
        None, "--branch", "-B",
        help="Branch name (skips AI naming). If omitted, Claude picks one.",
    ),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b", help="Base ref to branch from."
    ),
    auto: bool = typer.Option(
        False, "--auto",
        help="Non-interactive: run `claude -p`, stream output to .wk/output.md, exit when done.",
    ),
    yes: bool = typer.Option(
        False, "--yes", "-y",
        help="Skip the confirm-branch-name prompt.",
    ),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
    no_attach: bool = typer.Option(
        False, "--no-attach",
        help="Don't attach the tmux session (still creates it).",
    ),
) -> None:
    """Create a workspace and kick off Claude Code with [bold]PROMPT[/bold]."""
    require("git")
    require("tmux")
    require("claude")

    # Pick a branch name. Use the explicit one if given, otherwise ask Claude,
    # falling back to a deterministic slug.
    if branch is not None:
        if not _BRANCH_RE.match(branch):
            die(f"invalid branch name {branch!r}; want [a-z][a-z0-9-]{{2,59}}")
        source = "user"
    else:
        console.print("[dim]picking a branch name…[/dim]")
        branch, source = pick_branch_name(prompt)

    console.print(f"branch: [bold]{branch}[/bold] [dim]({source})[/dim]")

    if not yes and source != "user":
        # Let the user override before we touch git.
        # typer.prompt returns the user's input; empty = accept default.
        chosen = typer.prompt(
            "use this name? [enter to accept, or type a different name]",
            default=branch,
            show_default=False,
        ).strip() or branch
        if chosen != branch:
            if not _BRANCH_RE.match(chosen):
                die(f"invalid branch name {chosen!r}; want [a-z][a-z0-9-]{{2,59}}")
            branch = chosen

    session = session_name(branch)
    if session in tmux_sessions():
        die(f"tmux session already exists: {session}")

    # Create the worktree (strict: error if branch already exists).
    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=True)
    wt = state.wt

    # Write the task file. This is the durable record of what the workspace
    # is for, surfaced in the sidebar and readable by `claude` later.
    wk_dir = wt / ".wk"
    wk_dir.mkdir(exist_ok=True)
    task_file = wk_dir / "task.md"
    task_file.write_text(prompt.strip() + "\n", encoding="utf-8")
    # And a .gitignore inside .wk so the task notes don't accidentally
    # land in commits.
    (wk_dir / ".gitignore").write_text("*\n!.gitignore\n", encoding="utf-8")

    # Build the session. Agent command depends on --auto.
    if auto:
        # Non-interactive: pane 2 runs claude -p, output piped to .wk/output.md.
        # `tee` streams to both the pane and the file so the user can watch.
        # `read -n 1` keeps the pane open after exit for review.
        auto_cmd = (
            "claude -p \"$(cat .wk/task.md)\" 2>&1 | tee .wk/output.md; "
            "echo; echo '── task complete ── press any key to close ──'; "
            "read -n 1"
        )
        build_session(session, wt, " ".join(_shell_wrap(auto_cmd)))
    else:
        # Interactive: launch claude with the prompt as a positional arg so
        # it's pre-filled in the input buffer. Claude handles the launch
        # timing itself — no send-keys race condition.
        # We use shell-quoting via shlex for safety against unusual chars.
        import shlex
        agent = f"claude {shlex.quote(prompt.strip())}"
        build_session(session, wt, agent)

    # Tag the session as a task workspace so the sidebar can mark it.
    run(["tmux", "set-option", "-t", session, "@wk-task", "1"])
    run(["tmux", "set-option", "-t", session, "@wk-task-prompt", prompt.strip()[:200]])

    console.print(f"[green]✓[/green] task workspace [bold]{branch}[/bold] ready")
    console.print(f"  [dim]task file: {task_file}[/dim]")
    if auto:
        console.print(f"  [dim]output:    {wt}/.wk/output.md[/dim]")

    if not no_attach:
        attach_or_switch(session)


@app.command()
def restore(
    branch: Optional[str] = typer.Argument(
        None, help="Branch to restore. Omit to restore all worktrees missing a session."
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
) -> None:
    """Rebuild tmux session(s) for existing worktree(s).

    Use after a reboot or `tmux kill-server` to re-create the 4-pane layout
    on top of worktrees that still exist on disk. No git operations; the
    branch must already have a worktree.

    With no argument, rebuilds sessions for every wk worktree that currently
    lacks one — the "resurrect for wk" workflow.
    """
    require("git")
    require("tmux")

    sessions = tmux_sessions()
    worktrees = list_worktrees()
    if not worktrees:
        die("no worktrees to restore")

    targets: list[tuple[str, Path]] = []
    if branch is None:
        targets = [
            (b, p) for b, p in worktrees if session_name(b) not in sessions
        ]
        if not targets:
            console.print("[dim]all worktrees already have sessions[/dim]")
            return
    else:
        match = next(
            ((b, p) for b, p in worktrees if b == branch or session_name(b) == branch),
            None,
        )
        if match is None:
            die(f"no worktree for {branch!r}")
        b, p = match
        if session_name(b) in sessions:
            die(f"session {session_name(b)} already exists; use `wk switch` to attach")
        targets = [match]

    rebuilt: list[str] = []
    for b, p in targets:
        s = session_name(b)
        console.print(f"[dim]restoring {b}…[/dim]")
        build_session(s, p, agent_cmd())
        rebuilt.append(s)

    console.print(f"[green]✓[/green] restored {len(rebuilt)} workspace(s)")

    if not no_attach and len(rebuilt) == 1:
        attach_or_switch(rebuilt[0])


@app.command()
def is_wk_session(
    session: str = typer.Argument(..., help="Session name to check.")
) -> None:
    """Exit 0 if SESSION is a wk-managed session, 1 otherwise.

    For use in tmux-resurrect post-save hooks and shell scripts.
    """
    require("tmux")
    r = run(
        ["tmux", "show-options", "-v", "-t", session, "@wk"],
        check=False,
    )
    if r.returncode == 0 and r.stdout.strip() == "1":
        raise typer.Exit(0)
    raise typer.Exit(1)


@app.command("list")
@app.command("ls", hidden=True)
def list_cmd() -> None:
    """Show all workspaces with branch, status, and session state."""
    require("git")
    workspaces = all_workspaces()
    if not workspaces:
        console.print("[dim]no workspaces[/dim]")
        return

    table = Table(box=None, pad_edge=False)
    table.add_column("branch", style="bold")
    table.add_column("session")
    table.add_column("ahead/behind", justify="right")
    table.add_column("status")
    table.add_column("path", style="dim")

    for w in workspaces:
        sess = "[green]●[/green] " + w.session if w.has_session else f"[dim]○ {w.session}[/dim]"
        ab = f"+{w.ahead}/-{w.behind}" if (w.ahead or w.behind) else "[dim]·[/dim]"
        status = "[yellow]dirty[/yellow]" if w.dirty else "[green]clean[/green]"
        try:
            shown = "~/" + str(w.path.relative_to(Path.home()))
        except ValueError:
            shown = str(w.path)
        table.add_row(w.branch, sess, ab, status, shown)
    console.print(table)


@app.command()
def switch(
    branch: Optional[str] = typer.Argument(None, help="Branch; omit for fzf picker."),
) -> None:
    """Switch to an existing workspace."""
    require("tmux")
    workspaces = all_workspaces()
    if not workspaces:
        die("no workspaces to switch to")

    target: Optional[Workspace] = None
    if branch:
        for w in workspaces:
            if w.branch == branch or w.session == branch:
                target = w
                break
        if target is None:
            die(f"no workspace matching {branch!r}")
    else:
        require("fzf")
        lines = [
            f"{w.branch}\t{'●' if w.has_session else '○'}\t"
            f"{'dirty' if w.dirty else 'clean'}\t+{w.ahead}/-{w.behind}"
            for w in workspaces
        ]
        proc = subprocess.run(
            ["fzf", "--with-nth=1..", "--delimiter=\t", "--prompt=workspace> "],
            input="\n".join(lines),
            text=True,
            capture_output=True,
        )
        if proc.returncode != 0 or not proc.stdout.strip():
            raise typer.Exit(0)
        picked = proc.stdout.strip().split("\t", 1)[0]
        target = next(w for w in workspaces if w.branch == picked)

    # Ensure the session actually exists; rebuild if not
    if not target.has_session:
        console.print(f"[dim]session missing; rebuilding…[/dim]")
        build_session(target.session, target.path, agent_cmd())

    attach_or_switch(target.session)


@app.command()
def rm(
    branch: str = typer.Argument(..., help="Branch / workspace to remove."),
    force: bool = typer.Option(False, "--force", "-f", help="Remove even if dirty."),
    keep_branch: bool = typer.Option(
        False, "--keep-branch", help="Keep the branch ref after removing the worktree."
    ),
) -> None:
    """Kill the tmux session and remove the worktree."""
    require("git")
    require("tmux")
    main = repo_root()
    workspaces = {w.branch: w for w in all_workspaces()}
    w = workspaces.get(branch)
    if w is None:
        die(f"no workspace for {branch!r}")

    if w.dirty and not force:
        die(f"worktree is dirty; use --force or commit first")

    if w.has_session:
        run(["tmux", "kill-session", "-t", w.session], check=False)

    args = ["git", "-C", str(main), "worktree", "remove", str(w.path)]
    if force:
        args.append("--force")
    run(args)

    if not keep_branch:
        run(["git", "-C", str(main), "branch", "-D", branch], check=False)

    console.print(f"[green]✓[/green] removed {branch}")


@app.command()
def cd(
    branch: Optional[str] = typer.Argument(
        None, help="Print path for BRANCH; omit to use current tmux session."
    ),
) -> None:
    """Print the worktree path (for shell `cd`).

    Usage in fish:  cd (wk cd feature-x)
    """
    if branch is None:
        # Infer from current tmux session
        sess = os.environ.get("TMUX_PANE")
        if not sess:
            die("not inside tmux; pass a branch name")
        r = run(["tmux", "display-message", "-p", "#S"])
        session = r.stdout.strip()
        for w in all_workspaces():
            if w.session == session:
                print(w.path)
                return
        die(f"no workspace for current session {session!r}")
    else:
        for w in all_workspaces():
            if w.branch == branch or w.session == branch:
                print(w.path)
                return
        die(f"no workspace for {branch!r}")


@app.command()
def sidebar() -> None:
    """Interactive workspace sidebar (runs inside the leftmost tmux pane).

    Continuously lists workspaces and lets you switch by selecting one.
    Reads $WK_CURRENT to mark the active workspace.
    """
    require("fzf")
    require("tmux")
    current = os.environ.get("WK_CURRENT", "")
    wk = _wk_bin()

    # The preview script renders the workspace list with the current row marked.
    # We rebuild the list each loop iteration so dirty/ahead counts stay fresh.
    while True:
        workspaces = all_workspaces()
        if not workspaces:
            # No workspaces yet — show a hint and wait.
            console.clear()
            console.print("[dim](no workspaces)\nUse `wk new <branch>`[/dim]")
            try:
                # Sleep but allow Ctrl-C
                import time
                time.sleep(3)
                continue
            except KeyboardInterrupt:
                return

        # Build fzf input. Each line: marker, branch, ahead/behind, status.
        # We tab-delimit and hide the leading session-name field for switching.
        lines: list[str] = []
        for w in workspaces:
            marker = "▶" if w.session == current else (" " if w.has_session else "·")
            ab = f"+{w.ahead}/-{w.behind}" if (w.ahead or w.behind) else " "
            status = "✱" if w.dirty else " "
            # session\tdisplay
            display = f"{marker} {w.branch[:18]:<18} {ab:>8} {status}"
            lines.append(f"{w.session}\t{display}")

        # fzf in "loop" mode: returns selected session name on Enter, exits on Esc.
        # The outer Python loop re-renders the data each iteration, so Esc just
        # falls through to a re-render.
        proc = subprocess.run(
            [
                "fzf",
                "--with-nth=2..",
                "--delimiter=\t",
                "--no-info",
                "--no-scrollbar",
                "--prompt=workspaces❯ ",
                "--header=enter=switch  ctrl-n=new  ctrl-d=rm",
                "--reverse",
                "--height=100%",
                "--cycle",
                # Ctrl-N prompts for a new branch (via tmux) and creates it
                f"--bind=ctrl-n:execute(tmux command-prompt -p 'new branch:' 'run-shell \"{wk} new %%\"')+abort",
                # Ctrl-D removes the highlighted workspace (force)
                f"--bind=ctrl-d:execute({wk} rm {{1}} --force)+reload(sleep 0.2 && {wk} _list-once)",
            ],
            input="\n".join(lines),
            text=True,
            capture_output=True,
            env={**os.environ, "WK_CURRENT": current},
        )
        if proc.returncode == 130:  # Esc / Ctrl-C — just re-render the loop
            continue
        if proc.returncode != 0 or not proc.stdout.strip():
            # Sleep briefly to avoid busy-loop if fzf is unavailable mid-run
            import time
            time.sleep(0.2)
            continue

        picked_session = proc.stdout.strip().split("\t", 1)[0]
        if picked_session and picked_session != current:
            subprocess.run(["tmux", "switch-client", "-t", picked_session], check=False)
        # Loop continues — sidebar re-renders.


@app.command("_list-once", hidden=True)
def list_once() -> None:
    """Internal: dump a single sidebar listing (for fzf --reload)."""
    current = os.environ.get("WK_CURRENT", "")
    for w in all_workspaces():
        marker = "▶" if w.session == current else (" " if w.has_session else "·")
        ab = f"+{w.ahead}/-{w.behind}" if (w.ahead or w.behind) else " "
        status = "✱" if w.dirty else " "
        display = f"{marker} {w.branch[:18]:<18} {ab:>8} {status}"
        print(f"{w.session}\t{display}")


