@app.command()
def new(
    branch: str = typer.Argument(..., help="Branch name for the new workspace."),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b", help="Base ref to branch from."
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
) -> None:
    """Create a [bold]new[/bold] worktree + tmux session for BRANCH and attach.

    Errors if the branch already exists. For a forgiving "open whatever's
    there, or make it if not" command, use `wk open` instead.
    """
    require("git")
    require("tmux")

    session = session_name(branch)
    if session in tmux_sessions():
        die(f"tmux session already exists: {session}")

    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=True)

    build_session(state.session, state.wt, agent_cmd(), branch=state.branch)
    console.print(f"[green]✓[/green] workspace [bold]{state.branch}[/bold] ready at {state.wt}")

    if not no_attach:
        attach_or_switch(state.session)


@app.command("open")
def open_cmd(
    branch: str = typer.Argument(..., help="Branch name to open."),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b",
        help="Base ref (used only if creating a new branch).",
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
) -> None:
    """Open BRANCH — attach if running, rebuild if not, create if missing.

    Forgiving counterpart to `wk new`. Handles every case:

    \b
      branch + worktree + session all exist  →  attach
      branch + worktree exist, no session    →  rebuild session, attach
      branch exists, no worktree             →  add worktree, build, attach
      branch on remote, not local            →  fetch, track, build, attach
      branch nowhere                         →  create from --base, build, attach

    Worktrees created outside `wk` (e.g. `git worktree add ...` directly)
    are recognized; their existing path is used, not wk's preferred path.
    """
    require("git")
    require("tmux")

    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=False)

    if state.session in tmux_sessions():
        console.print(f"[dim]session running; attaching[/dim]")
    else:
        build_session(state.session, state.wt, agent_cmd(), branch=state.branch)
        if state.created:
            console.print(f"[green]✓[/green] workspace [bold]{state.branch}[/bold] ready at {state.wt}")
        else:
            console.print(f"[green]✓[/green] rebuilt session for [bold]{state.branch}[/bold]")

    if not no_attach:
        attach_or_switch(state.session)


@app.command()
def task(
    prompt: str = typer.Argument(..., help="The task description / prompt for Claude."),
    branch: Optional[str] = typer.Option(
        None, "--branch", "-B",
        help="Branch name (skips AI naming). If omitted, Claude picks one.",
    ),
    base: str = typer.Option(
        DEFAULT_BASE, "--base", "-b", help="Base ref to branch from."
    ),
    auto: bool = typer.Option(
        False, "--auto",
        help="Non-interactive: run `claude -p`, stream output to .wk/output.md, exit when done.",
    ),
    yes: bool = typer.Option(
        False, "--yes", "-y",
        help="Skip the confirm-branch-name prompt.",
    ),
    no_fetch: bool = typer.Option(False, "--no-fetch", help="Skip `git fetch`."),
    no_attach: bool = typer.Option(
        False, "--no-attach",
        help="Don't attach the tmux session (still creates it).",
    ),
) -> None:
    """Create a workspace and kick off Claude Code with [bold]PROMPT[/bold]."""
    require("git")
    require("tmux")
    require("claude")

    # Pick a branch name. Use the explicit one if given, otherwise ask Claude,
    # falling back to a deterministic slug.
    if branch is not None:
        if not _BRANCH_RE.match(branch):
            die(f"invalid branch name {branch!r}; want [a-z][a-z0-9-]{{2,59}}")
        source = "user"
    else:
        console.print("[dim]picking a branch name…[/dim]")
        branch, source = pick_branch_name(prompt)

    console.print(f"branch: [bold]{branch}[/bold] [dim]({source})[/dim]")

    if not yes and source != "user":
        # Let the user override before we touch git.
        # typer.prompt returns the user's input; empty = accept default.
        chosen = typer.prompt(
            "use this name? [enter to accept, or type a different name]",
            default=branch,
            show_default=False,
        ).strip() or branch
        if chosen != branch:
            if not _BRANCH_RE.match(chosen):
                die(f"invalid branch name {chosen!r}; want [a-z][a-z0-9-]{{2,59}}")
            branch = chosen

    session = session_name(branch)
    if session in tmux_sessions():
        die(f"tmux session already exists: {session}")

    # Create the worktree (strict: error if branch already exists).
    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=True)
    wt = state.wt

    # Write the task file. This is the durable record of what the workspace
    # is for, surfaced in the sidebar and readable by `claude` later.
    # `mark_wk_workspace` creates the .wk/ dir and its .gitignore.
    mark_wk_workspace(wt)
    task_file = wt / WK_MARKER_DIR / "task.md"
    task_file.write_text(prompt.strip() + "\n", encoding="utf-8")

    # Build the session. Agent command depends on --auto.
    if auto:
        # Non-interactive: pane 2 runs claude -p, output piped to .wk/output.md.
        # `tee` streams to both the pane and the file so the user can watch.
        # `read -n 1` keeps the pane open after exit for review.
        auto_cmd = (
            "claude -p \"$(cat .wk/task.md)\" 2>&1 | tee .wk/output.md; "
            "echo; echo '── task complete ── press any key to close ──'; "
            "read -n 1"
        )
        build_session(session, wt, " ".join(_shell_wrap(auto_cmd)), branch=branch)
    else:
        # Interactive: launch claude with the prompt as a positional arg so
        # it's pre-filled in the input buffer. Claude handles the launch
        # timing itself — no send-keys race condition.
        # We use shell-quoting via shlex for safety against unusual chars.
        import shlex
        agent = f"claude {shlex.quote(prompt.strip())}"
        build_session(session, wt, agent, branch=branch)

    # Tag the session as a task workspace so the sidebar can mark it.
    run(["tmux", "set-option", "-t", session, "@wk-task", "1"])
    run(["tmux", "set-option", "-t", session, "@wk-task-prompt", prompt.strip()[:200]])

    console.print(f"[green]✓[/green] task workspace [bold]{branch}[/bold] ready")
    console.print(f"  [dim]task file: {task_file}[/dim]")
    if auto:
        console.print(f"  [dim]output:    {wt}/.wk/output.md[/dim]")

    if not no_attach:
        attach_or_switch(session)


@app.command()
def restore(
    branch: Optional[str] = typer.Argument(
        None, help="Branch to restore. Omit to restore all worktrees missing a session."
    ),
    no_attach: bool = typer.Option(False, "--no-attach", help="Don't attach."),
) -> None:
    """Rebuild tmux session(s) for existing worktree(s).

    Use after a reboot or `tmux kill-server` to re-create the 4-pane layout
    on top of worktrees that still exist on disk. No git operations; the
    branch must already have a worktree.

    With no argument, rebuilds sessions for every wk worktree that currently
    lacks one — the "resurrect for wk" workflow.
    """
    require("git")
    require("tmux")

    sessions = tmux_sessions()
    worktrees = list_worktrees()
    if not worktrees:
        die("no worktrees to restore")

    targets: list[tuple[str, Path]] = []
    if branch is None:
        targets = [
            (b, p) for b, p in worktrees if session_name(b) not in sessions
        ]
        if not targets:
            console.print("[dim]all worktrees already have sessions[/dim]")
            return
    else:
        match = next(
            ((b, p) for b, p in worktrees if b == branch or session_name(b) == branch),
            None,
        )
        if match is None:
            die(f"no worktree for {branch!r}")
        b, p = match
        if session_name(b) in sessions:
            die(f"session {session_name(b)} already exists; use `wk switch` to attach")
        targets = [match]

    rebuilt: list[str] = []
    for b, p in targets:
        s = session_name(b)
        console.print(f"[dim]restoring {b}…[/dim]")
        build_session(s, p, agent_cmd(), branch=b)
        rebuilt.append(s)

    console.print(f"[green]✓[/green] restored {len(rebuilt)} workspace(s)")

    if not no_attach and len(rebuilt) == 1:
        attach_or_switch(rebuilt[0])


@app.command()
