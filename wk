def list_cmd() -> None:
    """Show all workspaces with branch, status, and session state.

    One row per worktree wk knows about: the session-state glyph (▶ current
    / ● running / · no session), branch, project-scoped session name,
    ahead/behind vs upstream, a ✱ when the worktree is dirty, and the path.
