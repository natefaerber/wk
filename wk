@app.command()
def switch(
    branch: Optional[str] = typer.Argument(None, help="Branch; omit for fzf picker."),
) -> None:
    """Switch to an existing workspace."""
    require("tmux")
    workspaces = all_workspaces()
    if not workspaces:
        die("no workspaces to switch to")

    target: Optional[Workspace] = None
    if branch:
        for w in workspaces:
            if w.branch == branch or w.session == branch:
                target = w
                break
        if target is None:
            die(f"no workspace matching {branch!r}")
    else:
        require("fzf")
        wk = _wk_bin()
        current = os.environ.get("WK_CURRENT", "")
        # Compute it ourselves if not exported (e.g. when run from a popup).
        if not current and in_tmux():
            r = run(["tmux", "display-message", "-p", "#S"], check=False)
            current = r.stdout.strip()

        lines: list[str] = []
        for w in workspaces:
            marker = "▶" if w.session == current else ("●" if w.has_session else "·")
            ab = f"+{w.ahead}/-{w.behind}" if (w.ahead or w.behind) else " "
            status = "✱" if w.dirty else " "
            display = f"{marker} {w.branch[:30]:<30} {ab:>8} {status}"
            lines.append(f"{w.session}\t{display}")

        proc = subprocess.run(
            [
                "fzf",
                "--with-nth=2",
                "--delimiter=\t",
                "--no-info",
                "--no-scrollbar",
                "--prompt=workspace❯ ",
                "--header=enter=switch  j/k=move  /=filter  ctrl-n=new  ctrl-d=rm",
                "--reverse",
                "--height=100%",
                "--cycle",
                # Preview shows task + recent commits + status. Visible by
                # default since the popup has room.
                f"--preview={wk} _preview {{1}}",
                "--preview-window=right:60%:wrap",
                "--bind=ctrl-p:toggle-preview",
                # Vim-style nav by default; `/` enters filter mode where
                # typing filters as usual. Esc keeps its fzf default (abort),
                # which is what dismisses the popup.
                "--disabled",
                "--bind=j:down,k:up,g:first,G:last",
                "--bind=/:unbind(j,k,g,G)+enable-search+clear-query",
                # ctrl-n / ctrl-d quick actions on the highlighted workspace
                f"--bind=ctrl-n:execute(tmux command-prompt -p 'new branch:' 'run-shell \"{wk} new %%\"')+abort",
                f"--bind=ctrl-d:execute({wk} rm {{1}} --force)+reload({wk} _list-once)",
            ],
            input="\n".join(lines),
            text=True,
            capture_output=True,
            env={**os.environ, "WK_CURRENT": current},
        )
        if proc.returncode != 0 or not proc.stdout.strip():
            raise typer.Exit(0)
        picked_session = proc.stdout.strip().split("\t", 1)[0]
        target = next(w for w in workspaces if w.session == picked_session)

    # Ensure the session actually exists; rebuild if not
    if not target.has_session:
        console.print(f"[dim]session missing; rebuilding…[/dim]")
        build_session(target.session, target.path, agent_cmd(), branch=target.branch)

    attach_or_switch(target.session)


@app.command()
def rm(
    branch: str = typer.Argument(..., help="Branch / workspace to remove."),
    force: bool = typer.Option(False, "--force", "-f", help="Remove even if dirty."),
    keep_branch: bool = typer.Option(
        False, "--keep-branch", help="Keep the branch ref after removing the worktree."
    ),
) -> None:
    """Kill the tmux session and remove the worktree."""
    require("git")
    require("tmux")
    main = repo_root()
    workspaces = {w.branch: w for w in all_workspaces()}
    w = workspaces.get(branch)
    if w is None:
        die(f"no workspace for {branch!r}")

    if w.dirty and not force:
        die(f"worktree is dirty; use --force or commit first")

    if w.has_session:
        run(["tmux", "kill-session", "-t", w.session], check=False)

    args = ["git", "-C", str(main), "worktree", "remove", str(w.path)]
    if force:
        args.append("--force")
    run(args)

    if not keep_branch:
        run(["git", "-C", str(main), "branch", "-D", branch], check=False)

    console.print(f"[green]✓[/green] removed {branch}")


