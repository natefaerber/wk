# branch-name + task helpers
# ---------------------------------------------------------------------------


# A valid branch name for our purposes: lowercase, hyphen-separated,
# starts with a letter, 3–60 chars. Loose enough to accept what Claude
# typically produces, strict enough to keep filesystem paths sane.
_BRANCH_RE = re.compile(r"^[a-z][a-z0-9-]{2,59}$")


def slugify(text: str, max_words: int = 5) -> str:
    """Deterministic fallback: take first words, lowercase, dash-separate.

    Used when the AI branch picker fails or is skipped. Always returns
    a string that matches _BRANCH_RE (min 3 chars, leading letter).
    """
    # Replace non-alphanumeric runs with spaces, then take the first N words.
    cleaned = re.sub(r"[^a-zA-Z0-9]+", " ", text).strip().lower()
    words = cleaned.split()[:max_words]
    slug = "-".join(words) if words else ""
    # Collapse repeated dashes, trim to 60.
    slug = re.sub(r"-+", "-", slug).strip("-")[:60]
    # Ensure leading letter and minimum length (3 chars per _BRANCH_RE).
    if not slug or not slug[0].isalpha():
        slug = f"task-{slug}".strip("-") if slug else f"task-{int(_time.time())}"
    if len(slug) < 3:
        slug = f"task-{slug}"
    return slug


_BRANCH_PROMPT = """\
You are naming a git branch for the following task. Reply with ONLY the
branch name — no quotes, no explanation, no markdown. Rules:

- lowercase
- 2 to 6 words joined by hyphens
- start with a letter
- describe the task (not the verb): "fix-flaky-session-test", not "fix"
- no slashes, no spaces, no underscores

Task:
{prompt}

Branch name:"""


def pick_branch_name(prompt: str, timeout_seconds: int = 30) -> tuple[str, str]:
    """Ask `claude -p` to suggest a branch name. Returns (name, source).

    `source` is "claude" on success, "slug" on fallback. Never raises;
    falls back to slugify() on timeout, network, parse, or validation errors.
    """
    if shutil.which("claude") is None:
        return slugify(prompt), "slug"
    try:
        proc = subprocess.run(
            ["claude", "-p", "--output-format", "json", _BRANCH_PROMPT.format(prompt=prompt)],
            capture_output=True,
            text=True,
            timeout=timeout_seconds,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return slugify(prompt), "slug"

    if proc.returncode != 0 or not proc.stdout.strip():
        return slugify(prompt), "slug"

    try:
        payload = json.loads(proc.stdout)
        raw = str(payload.get("result", "")).strip()
    except (json.JSONDecodeError, AttributeError):
        return slugify(prompt), "slug"

    # Claude sometimes wraps the name in backticks, quotes, or extra prose.
    # Take the last non-empty line, strip surrounding punctuation.
    last_line = raw.splitlines()[-1].strip() if raw.splitlines() else ""
    candidate = last_line.strip("`\"' \t.,").lower().replace(" ", "-").replace("_", "-")
    candidate = re.sub(r"-+", "-", candidate).strip("-")

    if _BRANCH_RE.match(candidate):
        return candidate, "claude"
    return slugify(prompt), "slug"


@dataclass
class WorkspaceState:
    """Result of resolving what to do for a `wk open` request.

    `branch` is the canonical git branch name (may contain slashes).
    `wt` is the worktree path that should be used (may be wk's preferred path,
    or an external path picked up from `git worktree list`).
    `created` is True if we created the worktree in this call.
    `branch_created` is True if we created the branch ref in this call.
    """
    branch: str
    wt: Path
    session: str
    created: bool
    branch_created: bool


def find_existing_worktree(branch: str) -> Optional[tuple[str, Path]]:
    """Look up an existing worktree for BRANCH, if any.

    Matches against the real branch name AND the session-form alias
    (`feat/admin-phase-1` matches input `feat-admin-phase-1`), since users
    often type the session-style name when invoking `wk open`.

    Returns (real_branch_name, path) on hit, or None.
    """
    r = run(["git", "worktree", "list", "--porcelain"], check=False)
    if r.returncode != 0:
        return None
    out = r.stdout
    cur_path: Optional[Path] = None
    for line in out.splitlines() + [""]:
        if line.startswith("worktree "):
            cur_path = Path(line[len("worktree ") :])
        elif line.startswith("branch "):
            ref = line[len("branch ") :].removeprefix("refs/heads/")
            if cur_path is not None and _query_matches(branch, ref):
                return ref, cur_path
        elif line == "":
            cur_path = None
    return None


def resolve_branch_alias(branch: str) -> str:
    """If BRANCH is a session-form alias (hyphens) of a real branch (slashes),
    return the real branch name. Otherwise return BRANCH unchanged.

    Looks across all local branches, not just ones with worktrees — so this
    works for branches the user hasn't checked out yet.
    """
    main = repo_root()
    r = run(
        ["git", "-C", str(main), "for-each-ref", "--format=%(refname:short)", "refs/heads/"],
        check=False,
    )
    if r.returncode != 0:
        return branch
    for ref in r.stdout.splitlines():
        ref = ref.strip()
        # Matches the real branch, its session-form slug, or the full
        # project-scoped session name.
        if _query_matches(branch, ref):
            return ref
    return branch


def branch_exists_locally(branch: str) -> bool:
    main = repo_root()
    r = run(
        ["git", "-C", str(main), "rev-parse", "--verify", f"refs/heads/{branch}"],
        check=False,
    )
    return r.returncode == 0


def branch_exists_on_remote(branch: str, remote: str = "origin") -> bool:
    """Does the branch exist on `remote` (after most-recent fetch)?"""
    main = repo_root()
    r = run(
        [
            "git", "-C", str(main),
            "rev-parse", "--verify", f"refs/remotes/{remote}/{branch}",
        ],
        check=False,
    )
    return r.returncode == 0


def resolve_workspace(
    branch: str,
    base: str,
    fetch: bool = True,
    strict_new: bool = False,
) -> WorkspaceState:
    """Resolve everything needed to open a workspace for BRANCH.

    Walks the six-case state space:

    1/2.  Branch + worktree exist (anywhere)         → use that worktree
    3.    Branch exists, no worktree                 → add worktree at wk's path
    4.    Branch missing locally, exists on remote   → fetch, create from remote
    5.    Branch missing entirely                    → create from BASE
    6.    (Same as 1/2 — external worktrees included)

    When `strict_new=True`, errors if the branch already exists. Used by
    `wk new` so it preserves its "I want a fresh thing" semantics.

    Does not build the tmux session — that's the caller's job. Returns
    a WorkspaceState describing what's now true on disk.
    """
    main = repo_root()

    # Normalize the input: if the user typed a session-form alias (hyphens),
    # find the real branch name (with slashes) so all downstream git ops use
    # the canonical ref. Prevents creating duplicate hyphen-named branches.
    branch = resolve_branch_alias(branch)
    session = session_name(branch)

    # 1/2/6. Existing worktree (wk-created or external).
    existing = find_existing_worktree(branch)
    if existing is not None:
        real_branch, existing_wt = existing
        if strict_new:
            die(f"branch {real_branch!r} already has a worktree at {existing_wt}")
        return WorkspaceState(
            branch=real_branch,
            wt=existing_wt, session=session_name(real_branch),
            created=False, branch_created=False,
        )

    # No worktree exists. Decide where to put one and how to create the branch.
    if fetch:
        console.print("[dim]fetching…[/dim]")
        run(
            ["git", "-C", str(main), "fetch", "--prune"],
            check=False, capture=True,
        )

    wt = worktree_path(branch)
    # Defensive: refuse to create on top of a non-empty directory that git
    # doesn't know about. That's almost always leftover crud worth surfacing.
    if wt.exists():
        die(
            f"path exists but isn't a registered git worktree: {wt}\n"
            f"  remove or rename it, then re-run"
        )

    wt.parent.mkdir(parents=True, exist_ok=True)
    # Nested `.worktrees/` would show as untracked in the main repo; exclude it.
    ensure_worktrees_ignored()

    if branch_exists_locally(branch):
        if strict_new:
            die(
                f"branch {branch!r} already exists locally; "
                f"use `wk open {branch}` to use it"
            )
        # Case 3.
        console.print(f"[dim]branch exists; checking out into worktree[/dim]")
        run(["git", "-C", str(main), "worktree", "add", str(wt), branch])
        return WorkspaceState(branch=branch, wt=wt, session=session, created=True, branch_created=False)

    if branch_exists_on_remote(branch):
        # Case 4. `git worktree add` with a local branch name that matches
        # a remote-tracking ref will set up tracking automatically.
        console.print(f"[dim]branch on remote; creating tracking branch[/dim]")
        run(
            ["git", "-C", str(main), "worktree", "add",
             "--track", "-b", branch, str(wt), f"origin/{branch}"],
        )
        return WorkspaceState(branch=branch, wt=wt, session=session, created=True, branch_created=True)

    # Case 5.
    # Verify the base ref resolves before branching from it — otherwise
    # `git worktree add` raises a bare CalledProcessError. Common on a repo with
    # no `origin` remote, or whose default branch isn't `main` (set WK_BASE or
    # pass --base).
    if run(
        ["git", "-C", str(main), "rev-parse", "--verify", "--quiet", base],
        check=False,
    ).returncode != 0:
        die(
            f"base ref {base!r} doesn't exist — fetch origin, or set WK_BASE "
            f"(or pass --base) to a ref that exists."
        )
    console.print(f"[dim]creating branch {branch} from {base}[/dim]")
    run(
        ["git", "-C", str(main), "worktree", "add", "-b", branch, str(wt), base]
    )
    return WorkspaceState(branch=branch, wt=wt, session=session, created=True, branch_created=True)


# ---------------------------------------------------------------------------
# ref resolution — branches, pull requests, and issue keys
# ---------------------------------------------------------------------------


# A github PR URL, e.g. https://github.com/owner/repo/pull/4670 (also
# matches ssh-style and trailing .git). Captures owner, repo, number.
_PR_URL_RE = re.compile(
    r"github\.com[:/]+(?P<owner>[^/\s]+)/(?P<repo>[^/\s]+?)(?:\.git)?/pull/(?P<number>\d+)",
    re.IGNORECASE,
)
# A git remote URL → owner/repo, for either https or ssh form.
_REMOTE_SLUG_RE = re.compile(
    r"github\.com[:/]+([^/\s]+)/([^/\s]+?)(?:\.git)?/?$",
    re.IGNORECASE,
)


def parse_pr_ref(ref: str) -> Optional[tuple[Optional[str], Optional[str], str]]:
    """Parse a PR reference into (owner, repo, number), or None if it isn't one.

    A bare number (``4670`` or ``#4670``) returns (None, None, "4670") —
    meaning "this PR in the current repo". A full GitHub PR URL returns
    the owner/repo parsed from the URL so we can locate that repo's clone.
    Anything else returns None, letting callers fall back to treating REF
    as a branch name.
    """
    ref = ref.strip()
    bare = ref.lstrip("#")
    if bare.isdigit():
        return None, None, bare
    m = _PR_URL_RE.search(ref)
    if m:
        return m.group("owner"), m.group("repo"), m.group("number")
    return None


def _remote_slug(url: str) -> Optional[str]:
    """Normalize a git remote URL to a lowercased ``owner/repo`` slug."""
    m = _REMOTE_SLUG_RE.search(url.strip())
    return f"{m.group(1)}/{m.group(2)}".lower() if m else None


def find_local_repo(owner: str, repo: str) -> Path:
    """Find the local clone of ``owner/repo`` under WK_PR_REPO_ROOT.

    Matches by `origin` remote slug rather than directory name, so a repo
    cloned into an oddly-named directory is still found. Dies with a
    helpful message when nothing matches; on multiple matches, prefers the
    clone closest to the search root and warns.
    """
    root = Path(os.environ.get(PR_REPO_ROOT_ENV, DEFAULT_PR_REPO_ROOT)).expanduser()
    if not root.is_dir():
        die(f"PR repo root not found: {root} (set {PR_REPO_ROOT_ENV})")

    want = f"{owner}/{repo}".lower()
    # `.git` is a directory in a normal clone but a file inside a worktree;
    # `-type d` finds the main checkouts and skips worktrees. `-prune` stops
    # find from descending into the (large) .git directory itself.
    r = run(
        ["find", str(root), "-maxdepth", "6", "-type", "d", "-name", ".git", "-prune"],
        check=False,
    )
    matches: list[Path] = []
    for git_dir in r.stdout.splitlines():
        repo_dir = Path(git_dir).parent
        u = run(
            ["git", "-C", str(repo_dir), "remote", "get-url", "origin"],
            check=False,
        )
        if u.returncode == 0 and _remote_slug(u.stdout) == want:
            matches.append(repo_dir)

    if not matches:
        die(
            f"no local clone of {want} found under {root}\n"
            f"  clone it first, or point {PR_REPO_ROOT_ENV} at where it lives"
        )

    # ~/_Work routinely holds several clones of the same repo (an old copy,
    # a scratch clone, a nested worktree). Disambiguate deterministically:
    # prefer a directory actually named after the repo, then one not buried
    # in a `.worktrees` dir, then the shallowest path.
    def rank(p: Path) -> tuple[int, int, int]:
        return (
            0 if p.name.lower() == repo.lower() else 1,
            1 if ".worktrees" in p.parts else 0,
            len(p.parts),
        )

    matches.sort(key=rank)
    # Only warn on a genuine tie — two clones both named exactly `repo`.
    named = [p for p in matches if p.name.lower() == repo.lower()]
    if len(named) > 1:
        warn(f"multiple clones named {repo}; using {matches[0]}")
    return matches[0]


def gh_pr_info(number: str, repo_slug: Optional[str] = None) -> dict:
    """Look up a PR with `gh` and return its JSON metadata as a dict.

    Fields consumed downstream: headRefName, isCrossRepository, title,
    state. `repo_slug` (owner/repo) targets a repo other than cwd's.
    """
    cmd = [
        "gh", "pr", "view", number,
        "--json", "headRefName,isCrossRepository,title,state",
    ]
    if repo_slug:
        cmd += ["--repo", repo_slug]
    r = run(cmd, check=False)
    if r.returncode != 0:
        msg = r.stderr.strip() or "gh pr view failed"
        die(f"couldn't look up PR #{number}: {msg}")
    try:
        return json.loads(r.stdout)
    except json.JSONDecodeError:
        die(f"unexpected gh output looking up PR #{number}")


# An issue-tracker URL (Jira cloud) or a bare issue key. Jira keys are
# uppercase (PROJ-123); the bare-key form requires uppercase so we don't
# mistake a lowercase branch name like `feat-12` for an issue key.
_JIRA_URL_RE = re.compile(r"atlassian\.net/browse/(?P<key>[A-Za-z][A-Za-z0-9]+-\d+)")
_ISSUE_KEY_RE = re.compile(r"^(?P<key>[A-Z][A-Z0-9]+-\d+)$")


def parse_issue_ref(ref: str) -> Optional[str]:
    """Return the uppercased issue key if REF is an issue link / key, else None.

    Accepts a Jira browse URL
    (``https://site.atlassian.net/browse/DEV-6266``) or a bare uppercase
    key (``DEV-6266``). A bare PR number falls through to `parse_pr_ref`.
    """
    ref = ref.strip()
    m = _JIRA_URL_RE.search(ref)
    if m:
        return m.group("key").upper()
    m = _ISSUE_KEY_RE.match(ref)
    return m.group("key").upper() if m else None


def _in_git_repo() -> bool:
    r = run(["git", "rev-parse", "--is-inside-work-tree"], check=False)
    return r.returncode == 0 and r.stdout.strip() == "true"


def _issue_search_owner() -> Optional[str]:
    """The GitHub org to scope the org-wide PR search to.

    WK_PR_SEARCH_OWNER wins; otherwise the owner of the current repo's
    `origin` remote. None when neither is available.
    """
    env = os.environ.get(PR_SEARCH_OWNER_ENV)
    if env:
        return env
    if _in_git_repo():
        u = run(["git", "remote", "get-url", "origin"], check=False)
        if u.returncode == 0:
            slug = _remote_slug(u.stdout)
            if slug:
                return slug.split("/", 1)[0]
    return None


def _pick_issue_pr(items: list[dict], key: str) -> Optional[dict]:
    """Choose the best PR for an issue from search results.

    Prefers results that genuinely have the key in their title (dropping
    GitHub full-text false positives), then open PRs, then the most recent
    (highest number).
    """
    key_l = key.lower()
    titled = [it for it in items if key_l in (it.get("title") or "").lower()]
    pool = titled or items
    if not pool:
        return None
    pool.sort(
        key=lambda it: (
            0 if (it.get("state") or "").lower() == "open" else 1,
            -int(it["number"]),
        )
    )
    return pool[0]


def find_pr_for_issue(key: str) -> Optional[tuple[Optional[str], str]]:
    """Find the PR referencing issue KEY → (repo_slug, number), or None.

    `repo_slug` is None when the hit came from the current repo (cwd is
    already correct). Searches the current repo first, then the org
    (`_issue_search_owner`). Uses an exact-phrase query so the hyphen in
    the key isn't tokenized into noise.
    """
    phrase = f'"{key}"'

    if _in_git_repo():
        r = run(
            ["gh", "pr", "list", "--search", phrase, "--state", "all",
             "--json", "number,title,state", "--limit", "30"],
            check=False,
        )
        if r.returncode == 0:
            try:
                items = json.loads(r.stdout)
            except json.JSONDecodeError:
                items = []
            pick = _pick_issue_pr(items, key)
            if pick is not None:
                return None, str(pick["number"])

    owner = _issue_search_owner()
    if owner:
        r = run(
            ["gh", "search", "prs", phrase, "--owner", owner,
             "--json", "repository,number,title,state", "--limit", "30"],
            check=False,
        )
        if r.returncode == 0:
            try:
                items = json.loads(r.stdout)
            except json.JSONDecodeError:
                items = []
            pick = _pick_issue_pr(items, key)
            if pick is not None:
                slug = (pick.get("repository") or {}).get("nameWithOwner")
                return slug, str(pick["number"])

    return None


def open_pr(
    number: str, repo_slug: Optional[str], no_attach: bool, no_fetch: bool
) -> None:
    """Open a workspace for PR `number`. cwd must already be the target repo.

    `repo_slug` (owner/repo) is forwarded to `gh --repo`; None means cwd's
    repo. Same-repo PRs become a tracking branch; fork PRs (or deleted head
    branches) are fetched via the pull ref.
    """
    info = gh_pr_info(number, repo_slug)
    head_ref = info.get("headRefName") or ""
    cross = bool(info.get("isCrossRepository"))
    title = info.get("title", "")
    state_label = info.get("state", "?")
    console.print(f"PR [bold]#{number}[/bold] {title} [dim]({state_label})[/dim]")

    main = repo_root()
    if not no_fetch:
        console.print("[dim]fetching…[/dim]")
        run(["git", "-C", str(main), "fetch", "--prune"], check=False, capture=True)

    # Same-repo PR whose head branch is still on origin → track it as a
    # normal branch. Fall through to the pull ref for fork PRs or deleted
    # head branches.
    if not cross and head_ref and branch_exists_on_remote(head_ref):
        state = resolve_workspace(head_ref, DEFAULT_BASE, fetch=False, strict_new=False)
        _build_and_attach(state, no_attach)
        return

    open_pr_pull_ref(number, no_attach)


def open_issue(key: str, base: str, no_attach: bool, no_fetch: bool) -> None:
    """Open a workspace for issue KEY: its PR if one exists, else a new branch.

    Resolves the issue to a PR (current repo, then org) and opens it. With
    no PR, starts fresh work: a workspace on a branch named after the key
    (``dev-6266``) off `base`, in the current repo.
    """
    found = find_pr_for_issue(key)
    if found is not None:
        repo_slug, number = found
        if repo_slug:
            owner, repo = repo_slug.split("/", 1)
            target = find_local_repo(owner, repo)
            os.chdir(target)
            console.print(f"[dim]repo: {repo_slug} at {target}[/dim]")
        console.print(f"[dim]{key} → PR #{number}[/dim]")
        open_pr(number, repo_slug, no_attach, no_fetch)
        return

    # No PR yet — start the work. This needs a repo to branch in.
    if not _in_git_repo():
        die(
            f"no PR found for {key}, and not inside a git repo to start a "
            f"branch in\n  cd into the target repo and re-run"
        )
    branch = key.lower()
    console.print(f"[dim]no PR found for {key}; starting branch {branch}[/dim]")
    state = resolve_workspace(branch, base, fetch=not no_fetch, strict_new=False)
    _build_and_attach(state, no_attach)


def open_pr_ref(
    owner: Optional[str], repo: Optional[str], number: str,
    no_attach: bool, no_fetch: bool,
) -> None:
    """Open a PR given its parsed (owner, repo, number).

    When owner/repo are set (a URL), locate that repo's clone under
    WK_PR_REPO_ROOT and `cd` into it first — every downstream git/worktree
    op resolves against cwd. owner/repo None means the current repo.
    """
    repo_slug: Optional[str] = None
    if owner and repo:
        repo_slug = f"{owner}/{repo}"
        target = find_local_repo(owner, repo)
        os.chdir(target)
        console.print(f"[dim]repo: {repo_slug} at {target}[/dim]")
    open_pr(number, repo_slug, no_attach, no_fetch)


def open_ref(ref: str, base: str, no_attach: bool, no_fetch: bool,
             layout: Optional[str] = None) -> None:
    """Open whatever REF points at — an issue, a pull request, or a branch.

    Classification, in order: an issue reference (Jira link or uppercase
    ``KEY-123``) → resolve to its PR or start the work; a PR reference
    (bare number or github PR URL) → open that PR; anything else → treat as
    a branch name, exactly like the original `wk open`. Only the issue and
    PR paths need `gh`, so it's required lazily.
    """
    issue_key = parse_issue_ref(ref)
    if issue_key:
        require("gh")
        open_issue(issue_key, base=base, no_attach=no_attach, no_fetch=no_fetch)
        return

    pr_ref = parse_pr_ref(ref)
    if pr_ref is not None:
        require("gh")
        owner, repo, number = pr_ref
        open_pr_ref(owner, repo, number, no_attach, no_fetch)
        return

    state = resolve_workspace(ref, base, fetch=not no_fetch, strict_new=False)
    _build_and_attach(state, no_attach, layout=layout)


def _build_and_attach(state: WorkspaceState, no_attach: bool,
                      layout: Optional[str] = None) -> None:
    """Build (or reuse) the tmux session for a resolved workspace, then attach.

    Shared by `wk open` and `wk pr`: attach if the session is already
    running, otherwise build the layout first (LAYOUT picks the profile;
    None auto-detects).
    """
    if state.session in tmux_sessions():
        console.print("[dim]session running; attaching[/dim]")
    else:
        build_session(state.session, state.wt, agent_cmd(), branch=state.branch, layout=layout)
        if state.created:
            console.print(f"[green]✓[/green] workspace [bold]{state.branch}[/bold] ready at {state.wt}")
        else:
            console.print(f"[green]✓[/green] rebuilt session for [bold]{state.branch}[/bold]")
    if not no_attach:
        attach_or_switch(state.session)


def open_pr_pull_ref(number: str, no_attach: bool) -> None:
    """Check out a PR via its GitHub ``refs/pull/<n>/head`` ref.

    Used for fork PRs (whose head branch isn't on `origin`) and for PRs
    whose head branch has been deleted from `origin`. Creates or reuses a
    local ``pr-<n>`` branch and a worktree for it. The pull ref is the one
    thing GitHub guarantees exists for any PR regardless of fork.
    """
    main = repo_root()
    branch = f"pr-{number}"

    existing = find_existing_worktree(branch)
    if existing is not None:
        real_branch, wt = existing
        _build_and_attach(
            WorkspaceState(
                branch=real_branch, wt=wt, session=session_name(real_branch),
                created=False, branch_created=False,
            ),
            no_attach,
        )
        return

    wt = worktree_path(branch)
    if wt.exists():
        die(
            f"path exists but isn't a registered git worktree: {wt}\n"
            f"  remove or rename it, then re-run"
        )
    wt.parent.mkdir(parents=True, exist_ok=True)
    # Nested `.worktrees/` would show as untracked in the main repo; exclude it.
    ensure_worktrees_ignored()

    if branch_exists_locally(branch):
        console.print(f"[dim]branch {branch} exists; checking out into worktree[/dim]")
    else:
        pull_ref = f"pull/{number}/head"
        console.print(f"[dim]fetching {pull_ref} → {branch}[/dim]")
        run(["git", "-C", str(main), "fetch", "origin", f"{pull_ref}:{branch}"])

    run(["git", "-C", str(main), "worktree", "add", str(wt), branch])
    _build_and_attach(
        WorkspaceState(
            branch=branch, wt=wt, session=session_name(branch),
            created=True, branch_created=True,
        ),
        no_attach,
    )


